#include "i3c_controller.h"
#include "uart.h"
#include "utils.h"
#include "reg_access.h"
#include <stdio.h>
#include <stdbool.h>
#include "sys_platform.h"

#define I3C_SLAVE_NUMS 1
#define SLAVE_ADDR 0x20

#ifdef GPIO_INST_BASE_ADDR
#include "gpio.h"
struct gpio_instance gpio_inst;
#endif

struct uart_instance uart_core_uart;
struct i3c_master_instance i3cm;
struct i3c_dev_info i3c_devinfo;

#ifdef LSCC_STDIO_UART_APB
struct uart_instance *g_stdio_uart;
#endif

// Simple blocking delay
static void simple_delay_ms(uint32_t ms) {
	// Approximation assuming roughly ~50MHz clock. 
	// Adjust multiplier if the blink speed is too fast/slow.
	for (volatile uint32_t i = 0; i < (ms * 10000); i++);
}

static void bsp_init(void)
{
#ifdef GPIO_INST_BASE_ADDR
	//initialize GPIO
	gpio_inst.instance_name = GPIO_INST_NAME;
	gpio_init(&gpio_inst, GPIO_INST_BASE_ADDR, GPIO_INST_LINES_NUM, GPIO_INST_GPIO_DIRS);
#endif

	uart_init(&uart_core_uart, UART0_INST_BASE_ADDR, UART0_INST_SYS_CLK, UART0_INST_BAUD_RATE, 1, 8);

#ifdef LSCC_STDIO_UART_APB
	g_stdio_uart = &uart_core_uart;
#endif
}

int main(void) {
	bsp_init();

	printf("Started! Running 4-second LED breathing effect...\n");

	// Step 1: 4 Seconds "Breathing" (or sweeping) LED startup
	// We'll run a loop for ~4000ms. 
	// Sweeping LEDs from index 0 to 3 continuously.
	uint32_t sweep_time_ms = 0;
	uint8_t sweep_idx = 0;
	while (sweep_time_ms < 2000) {
#ifdef GPIO_INST_BASE_ADDR
		gpio_output_write(&gpio_inst, sweep_idx, 0x00); // Turn ON current LED (assuming 0 is ON)
#endif
		simple_delay_ms(100); 
		
#ifdef GPIO_INST_BASE_ADDR
		gpio_output_write(&gpio_inst, sweep_idx, 0xFF); // Turn OFF current LED
#endif
		
		sweep_idx++;
		if (sweep_idx >= 4) { // Assuming 4 LEDs hook up
			sweep_idx = 0;
		}
		sweep_time_ms += 100;
	}

	// Step 2: Initialize I3C Master and Auto-Tune Timing Parameters
	printf("Starting I3C Master Configuration...\n");
	bool i3c_success = false;

	// Perform a base initialization first to load up the struct
	if (i3c_master_init(&i3cm, I3C_M_INST_BASE_ADDR, 0, I3C_M_INST_GUI_I2C_SCL_PULSE_WIDTH - 1, 1) != 0) {
		printf("I3C master base initialization FAILED! Cannot proceed.\n");
	} else {
		printf("I3C Master init OK. Beginning continuous scan for Slave...\n");

		// Step 2.5: Continuous Scan Loop with 8-LED Breathing Animation
		// The Master will constantly send out DAA requests until the Slave wakes up and responds.
		uint8_t anim_idx = 0;
		uint8_t anim_dir = 1; // 1 for sweeping up, 0 for sweeping down

		// We will test timing parameters. For simplicity, let's test a stable safe value 
		// or iterate safely. Since the user wants to "keep sending until received",
		// we'll loop standard safe values or a sweep continuously.
		
		uint8_t clk_val = 15; // Slower clock for better stability
		uint8_t od_val = 15;  // Max OD timer for stability

		// Apply safe timing parameters once
		uint8_t ctrl_val = 0;
		reg_8b_read(i3cm.base_addr | 0x04, &ctrl_val);
		reg_8b_write(i3cm.base_addr | 0x04, ctrl_val & ~0x01); // Disable
		reg_8b_write(i3cm.base_addr | 0x00, clk_val); 
		reg_8b_write(i3cm.base_addr | 0x1A, od_val);
		reg_8b_write(i3cm.base_addr | 0x04, ctrl_val | 0x01); // Enable

		while (!i3c_success) {
			// 1. Hardware Animation: 8-LED sweeping back and forth (Cylon/Knight Rider effect)
#ifdef GPIO_INST_BASE_ADDR
			for (int j = 0; j < 8; j++) {
				if (j == anim_idx) {
					gpio_output_write(&gpio_inst, j, 0x00); // Turn ON current LED (assuming 0 is ON)
				} else {
					gpio_output_write(&gpio_inst, j, 0xFF); // Turn OFF other LEDs
				}
			}
#endif
			// Update animation index
			if (anim_dir) {
				anim_idx++;
				if (anim_idx >= 7) anim_dir = 0;
			} else {
				anim_idx--;
				if (anim_idx <= 0) anim_dir = 1;
			}
			
			// Small delay for the animation speed
			simple_delay_ms(100);

			// 2. Test DAA (probe Slave)
			i3c_devinfo.pid = 0;
			uint8_t dyn_address = 0;
			uint8_t ret = i3c_master_daa(&i3cm, &i3c_devinfo, &dyn_address, I3C_SLAVE_NUMS, SLAVE_ADDR);

			if (ret == 0) {
				printf("\n>> SUCCESS! I3C Slave Found and Assigned!\n");
				i3c_success = true;
				// Exit the while loop since Slave was found
			} else {
				printf("."); // Print progress dot indicating search is ongoing
				
				// Reset IP to clear any hung NACK state
				reg_8b_write(i3cm.base_addr | 0x0C, 0x01); 
				simple_delay_ms(5);
				reg_8b_write(i3cm.base_addr | 0x0C, 0x00); 
			}
		}
	}

	// Step 3: LED Status Indicator Loop (Success State)
	printf("\nEntering Success Flashing Mode.\n");
	uint8_t pin_state = 0x00; // start with all ON
	while (true) {
#ifdef GPIO_INST_BASE_ADDR
		if (i3c_success) {
			// All 8 lights flashing if success
			for (int j = 0; j < 8; j++) {
				gpio_output_write(&gpio_inst, j, pin_state);
			}
			pin_state = ~pin_state; // Toggle
			simple_delay_ms(500); // 500ms flash rate
		} else {
			// Just turn ON LED 0 to indicate failure (Should not hit this in continuous mode, but kept for safety)
			gpio_output_write(&gpio_inst, 0, 0x00); 
			for (int j = 1; j < 8; j++) {
				gpio_output_write(&gpio_inst, j, 0xFF); 
			}
			simple_delay_ms(500);
		}
#else
		if (i3c_success) {
			printf("Flashing OK: 0x%02X\n", pin_state);
			pin_state = ~pin_state;
		} else {
			printf("Failed: LED0 ON\n");
		}
		simple_delay_ms(1000);
#endif
	}

	return 0;
}

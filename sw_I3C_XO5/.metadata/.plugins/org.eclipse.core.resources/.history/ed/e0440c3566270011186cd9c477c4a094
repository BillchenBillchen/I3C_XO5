#include "i3c_controller.h"
#include "i3c_target.h"
#include "uart.h"
#include "utils.h"
#include <stdio.h>
#include <string.h>
#include "sys_platform.h"
#include "gpio.h"
#include "iob.h"

#define I3C_SLAVE_NUMS 1
#define DATA_LENGTH 32
#define SLAVE_ADDR 0x20

struct uart_instance uart_core_uart;
struct i3c_master_instance i3cm;
struct i3c_target_handle_t i3ct;
struct i3c_dev_info i3c_devinfo;
struct gpio_instance led_gpio;

const uint8_t wr_buf[DATA_LENGTH] = {
    0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07,
    0x08, 0x09, 0x0A, 0x0B, 0x0C, 0x0D, 0x0E, 0x0F,
    0x10, 0x11, 0x12, 0x13, 0x14, 0x15, 0x16, 0x17,
    0x18, 0x19, 0x1A, 0x1B, 0x1C, 0x1D, 0x1E, 0x1F
};
uint8_t rd_buf[DATA_LENGTH];
unsigned int target_tx_buf[DATA_LENGTH];

// --- stdio 路由函式 (必須保留以支援 printf) ---
static int lscc_uart_putc(char c, FILE *file) {
    int ret = uart_putc(&uart_core_uart, c);
    if (c == '\n' && ret == 0)
        ret = uart_putc(&uart_core_uart, '\r');
    return ret;
}
static int lscc_uart_getc(FILE *file) { return EOF; }
static int lscc_uart_flush(FILE *file) { return EOF; }

int main(void) {
    uint8_t ret = 0;
    int i;
    uint8_t dyn_address;

    i3c_devinfo.pid = 0;

    // --- UART Init ---
    uart_init(&uart_core_uart, UART0_INST_BASE_ADDR, UART0_INST_SYS_CLK, UART0_INST_BAUD_RATE, 1, 8);
    iob_init(lscc_uart_putc, lscc_uart_getc, lscc_uart_flush);

    // --- GPIO Init ---
    gpio_init(&led_gpio, GPIO0_INST_BASE_ADDR, GPIO0_INST_LINES_NUM, GPIO0_INST_GPIO_DIRS);
    gpio_set_direction(&led_gpio, 0, GPIO_OUTPUT); // LED0
    gpio_set_direction(&led_gpio, 1, GPIO_OUTPUT); // LED1
    gpio_output_write(&led_gpio, 0, 0); // LED0 OFF
    gpio_output_write(&led_gpio, 1, 0); // LED1 OFF

    printf("\n\nSTARTING I3C DUAL-ROLE TEST...\n");

    // ==========================================
    // 1. Initialize Master & Target IPs
    // ==========================================
    if (i3c_master_init(&i3cm, I3C_M_INST_BASE_ADDR, 0,
                        I3C_M_INST_GUI_I2C_SCL_PULSE_WIDTH - 1, I3C_SLAVE_NUMS) == 0) {
        printf("I3C master init success\n");
    } else {
        printf("Fail to initialize I3C master\n");
        while(1);
    }

    i3ct.base_addr = I3C_S_INST_BASE_ADDR;
    if (i3c_target_init(&i3ct) == 0) {
        printf("I3C target init success\n");
    } else {
        printf("Fail to initialize I3C target\n");
        while(1);
    }

    // ==========================================
    // 2. DAA (Master drives, Target HW replies autonomously)
    // ==========================================
    gpio_output_write(&led_gpio, 0, 1); // LED0 ON (DAA in progress)
    printf("STARTING DAA TEST...\n");
    ret = i3c_master_daa(&i3cm, &i3c_devinfo, &dyn_address, I3C_SLAVE_NUMS, SLAVE_ADDR);
    if (ret) {
        printf("Fail I3C master DAA: error = %d\n", ret);
        while(1);
    }
    printf("Command DAA success\n");

    // ==========================================
    // 3. [CRITICAL] Target Pre-fills TX FIFO
    //    Must happen before Master initiates Read,
    //    otherwise Target TX FIFO is empty and the
    //    transaction hangs or returns garbage.
    // ==========================================
    printf("Pre-filling Target TX FIFO...\n");
    for (i = 0; i < DATA_LENGTH; i++) {
        target_tx_buf[i] = wr_buf[i];
    }
    i3ct.buf = target_tx_buf;
    i3ct.len = DATA_LENGTH;
    i3c_target_private_write(&i3ct);
    printf("Target TX FIFO pre-filled successfully!\n");

    // ==========================================
    // 4. Repeated Start WR + RD (from Master side)
    // ==========================================
    printf("STARTING I3C TESTS: Repeated Start WR + RD ...\n");

    uint8_t actual_rd_length = 0;
    uint8_t expected_rd_length = DATA_LENGTH - 2;

    ret = i3c_master_private_i3c_write_repeated_start_read_handle_early_term(
              &i3cm,
              (uint8_t *) wr_buf, DATA_LENGTH,
              SLAVE_ADDR,
              expected_rd_length,
              (uint8_t *) rd_buf,
              &actual_rd_length);

    // ==========================================
    // 5. Final Result Evaluation
    // ==========================================
    gpio_output_write(&led_gpio, 0, 0); // LED0 OFF
    gpio_output_write(&led_gpio, 1, 0); // LED1 OFF

    if (ret != 0) {
        // Fatal Error (e.g., NACK) -> LED1 ON
        printf("WR+RD error: ret=%d\n", ret);
        gpio_output_write(&led_gpio, 1, 1); // LED1 ON
        while(1);
    }
    else if (actual_rd_length < expected_rd_length) {
        // Early Termination / Underflow -> Flash LED0 and LED1
        printf("Early Termination: got %d bytes, expected %d\n",
               actual_rd_length, expected_rd_length);
        while(1) {
            gpio_output_write(&led_gpio, 0, 1); // LED0 ON
            gpio_output_write(&led_gpio, 1, 1); // LED1 ON
            delayMS(200);
            gpio_output_write(&led_gpio, 0, 0); // LED0 OFF
            gpio_output_write(&led_gpio, 1, 0); // LED1 OFF
            delayMS(200);
        }
    }
    else {
        uint8_t mismatch = 0;
        for (i = 0; i < expected_rd_length; i++) {
            if (rd_buf[i] != wr_buf[i]) mismatch = 1;
        }

        if (mismatch) {
            // Data Mismatch -> LED1 Blinks, LED0 OFF
            printf("Data mismatch!\n");
            while(1) {
                gpio_output_write(&led_gpio, 0, 0); // LED0 OFF
                gpio_output_write(&led_gpio, 1, 1); // LED1 ON
                delayMS(200);
                gpio_output_write(&led_gpio, 1, 0); // LED1 OFF
                delayMS(200);
            }
        } else {
            // Success -> LED0 ON, LED1 OFF
            printf("Read data matches write data. SUCCESS!\n");
            gpio_output_write(&led_gpio, 0, 1); // LED0 ON
            gpio_output_write(&led_gpio, 1, 0); // LED1 OFF
            while(1);
        }
    }

    return 0;
}

#include "i3c_controller.h"
#include "uart.h"
#include "utils.h"
#include <stdio.h>
#include <stdbool.h>
#include "sys_platform.h"

#define I3C_SLAVE_NUMS 1
#define SLAVE_ADDR 0x20

#ifdef GPIO_INST_BASE_ADDR
#include "gpio.h"
struct gpio_instance gpio_inst;
#endif

struct uart_instance uart_core_uart;
struct i3c_master_instance i3cm;
struct i3c_dev_info i3c_devinfo;

#ifdef LSCC_STDIO_UART_APB
struct uart_instance *g_stdio_uart;
#endif

// Simple blocking delay
static void simple_delay_ms(uint32_t ms) {
	// Approximation assuming roughly ~50MHz clock. 
	// Adjust multiplier if the blink speed is too fast/slow.
	for (volatile uint32_t i = 0; i < (ms * 10000); i++);
}

static void bsp_init(void)
{
#ifdef GPIO_INST_BASE_ADDR
	//initialize GPIO
	gpio_inst.instance_name = GPIO_INST_NAME;
	gpio_init(&gpio_inst, GPIO_INST_BASE_ADDR, GPIO_INST_LINES_NUM, GPIO_INST_GPIO_DIRS);
#endif

	uart_init(&uart_core_uart, UART0_INST_BASE_ADDR, UART0_INST_SYS_CLK, UART0_INST_BAUD_RATE, 1, 8);

#ifdef LSCC_STDIO_UART_APB
	g_stdio_uart = &uart_core_uart;
#endif
}

int main(void) {
	bsp_init();

	printf("Started! Running 4-second LED breathing effect...\n");

	// Step 1: 4 Seconds "Breathing" (or sweeping) LED startup
	// We'll run a loop for ~4000ms. 
	// Sweeping LEDs from index 0 to 3 continuously.
	uint32_t sweep_time_ms = 0;
	uint8_t sweep_idx = 0;
	while (sweep_time_ms < 4000) {
#ifdef GPIO_INST_BASE_ADDR
		gpio_output_write(&gpio_inst, sweep_idx, 0x00); // Turn ON current LED (assuming 0 is ON)
#endif
		simple_delay_ms(100); 
		
#ifdef GPIO_INST_BASE_ADDR
		gpio_output_write(&gpio_inst, sweep_idx, 0xFF); // Turn OFF current LED
#endif
		
		sweep_idx++;
		if (sweep_idx >= 4) { // Assuming 4 LEDs hook up
			sweep_idx = 0;
		}
		sweep_time_ms += 100;
	}

	// Step 2: Initialize I3C Master
	printf("Initializing I3C Master...\n");
	bool i3c_success = false;
	
	// Notice we use the local I3C_M_INST_* macros defined for THIS project
	if (i3c_master_init(&i3cm, I3C_M_INST_BASE_ADDR, 0, I3C_M_INST_GUI_I2C_SCL_PULSE_WIDTH - 1, 1) == 0) {
		printf("I3C master initialization SUCCESS!\n");
		
		// Step 2.5: Wait 3 seconds for Slave to boot up
		printf("Waiting 3 seconds for I3C Slave to boot...\n");
		simple_delay_ms(3000);

		// Step 2.6: Probe the Slave with DAA
		printf("Probing for I3C Slave via DAA...\n");
		i3c_devinfo.pid = 0;
		uint8_t dyn_address = 0;
		uint8_t ret = i3c_master_daa(&i3cm, &i3c_devinfo, &dyn_address, I3C_SLAVE_NUMS, SLAVE_ADDR);
		
		if (ret == 0) {
			printf("DAA test success! I3C Slave found.\n");
			i3c_success = true;
		} else {
			printf("DAA test failed! Error = %d (Slave missing/NACK)\n", ret);
			i3c_success = false;
		}
	} else {
		printf("I3C master initialization FAILED.\n");
		i3c_success = false;
	}

	// Step 3: LED Status Indicator Loop
	uint8_t pin_state = 0x00; // start with all ON
	while (true) {
#ifdef GPIO_INST_BASE_ADDR
		if (i3c_success) {
			// All lights flashing if success
			for (int j = 0; j < 4; j++) {
				gpio_output_write(&gpio_inst, j, pin_state);
			}
			pin_state = ~pin_state; // Toggle
			simple_delay_ms(500); // 500ms flash rate
		} else {
			// Just turn ON LED 0 to indicate failure
			gpio_output_write(&gpio_inst, 0, 0x00); 
			for (int j = 1; j < 4; j++) {
				gpio_output_write(&gpio_inst, j, 0xFF); 
			}
			simple_delay_ms(1000);
		}
#else
		if (i3c_success) {
			printf("Flashing OK: 0x%02X\n", pin_state);
			pin_state = ~pin_state;
		} else {
			printf("Failed: LED0 ON\n");
		}
		simple_delay_ms(1000);
#endif
	}

	return 0;
}

<?xml version="1.0" encoding="utf-8" standalone="no"?>
    <device schemaVersion="1.1" xmlns:xs="http://www.w3.org/2001/XMLSchema-instance" xs:noNamespaceSchemaLocation="CMSIS-SVD.xsd" >
      <vendor>Latticsemi.com</vendor>                                       <!-- device vendor name -->
      <vendorID>Latticesemi</vendorID>                                        <!-- device vendor short name -->
      <name>LFMXO5_25</name>                                        <!-- name of part-->
      <series>LFMXO5</series>                                         <!-- device series the device belongs to -->
      <version>1.0</version>                                          <!-- version of this description, adding CMSIS-SVD 1.1 tags -->
      <description>I3C_XO5</description>

      <addressUnitBits>8</addressUnitBits>
      <width>32</width>
      <size>32</size>
      <access>read-write</access>
      <resetValue>0x00000000</resetValue>
      <resetMask>0xFFFFFFFF</resetMask>

      <peripherals>
          <peripheral>
          <name>gpio0_inst</name>
          <version>1.8.0</version>
          <baseAddress>0x00010000</baseAddress>
          <groupName>gpio</groupName>
          <description></description>

          <addressBlock>
            <offset>0x0</offset>
            <size>0x00000400</size>
            <usage>registers</usage>
          </addressBlock>

          <registers>
                <!-- RD_DATA_REG: Read Data Register -->
            <register>
              <name>RD_DATA_REG</name>
              <description>Read Data Register</description>
              <addressOffset>0x0000</addressOffset>
              <size>32</size>
              <access>read-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- rd_data: Read actual values of GPIO's -->
                <field>
                  <name>rd_data</name>
                  <description>Read actual values of GPIO's</description>
                  <bitRange>[11:0]</bitRange>
                  <access>read-only</access>
                </field>

              </fields>
           </register>

      <!-- WR_DATA_REG: Write Data Register -->
            <register>
              <name>WR_DATA_REG</name>
              <description>Write Data Register</description>
              <addressOffset>0x0004</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- wr_data: Write GPIO output register -->
                <field>
                  <name>wr_data</name>
                  <description>Write GPIO output register</description>
                  <bitRange>[11:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- SET_DATA_REG: Set Data Register -->
            <register>
              <name>SET_DATA_REG</name>
              <description>Set Data Register</description>
              <addressOffset>0x0008</addressOffset>
              <size>32</size>
              <access>write-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- set_data: Set GPIO output register -->
                <field>
                  <name>set_data</name>
                  <description>Set GPIO output register</description>
                  <bitRange>[11:0]</bitRange>
                  <access>write-only</access>
                </field>

              </fields>
           </register>

      <!-- CLEAR_DATA_REG: Clear Data Register -->
            <register>
              <name>CLEAR_DATA_REG</name>
              <description>Clear Data Register</description>
              <addressOffset>0x000C</addressOffset>
              <size>32</size>
              <access>write-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- clear_data: Clear GPIO output register -->
                <field>
                  <name>clear_data</name>
                  <description>Clear GPIO output register</description>
                  <bitRange>[11:0]</bitRange>
                  <access>write-only</access>
                </field>

              </fields>
           </register>

      <!-- DIRECTION_REG: Direction Register -->
            <register>
              <name>DIRECTION_REG</name>
              <description>Direction Register</description>
              <addressOffset>0x0010</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- direction_reg: GPIO Direction register -->
                <field>
                  <name>direction_reg</name>
                  <description>GPIO Direction register</description>
                  <bitRange>[11:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- INT_TYPE_REG: Interrupt Type Register -->
            <register>
              <name>INT_TYPE_REG</name>
              <description>Interrupt Type Register</description>
              <addressOffset>0x0014</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- int_type: Interrupt Type Cofiguration Register, 1-Edge, 0-Level -->
                <field>
                  <name>int_type</name>
                  <description>Interrupt Type Cofiguration Register, 1-Edge, 0-Level</description>
                  <bitRange>[11:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- INT_METHOD_REG: Interrupt Method Register -->
            <register>
              <name>INT_METHOD_REG</name>
              <description>Interrupt Method Register</description>
              <addressOffset>0x0018</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- int_method: Interrupt Method Register, if Interrupt Type is Edge` 1-Rising edge 0-faling edge, if Interrupt Type is Level` 1-High level, 0-Low level -->
                <field>
                  <name>int_method</name>
                  <description>Interrupt Method Register, if Interrupt Type is Edge` 1-Rising edge 0-faling edge, if Interrupt Type is Level` 1-High level, 0-Low level</description>
                  <bitRange>[11:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- INT_STATUS_REG: Interrupt Status Register -->
            <register>
              <name>INT_STATUS_REG</name>
              <description>Interrupt Status Register</description>
              <addressOffset>0x001C</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- int_status: Interrupt Status Register, indicates interrupt status -->
                <field>
                  <name>int_status</name>
                  <description>Interrupt Status Register, indicates interrupt status</description>
                  <bitRange>[11:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- INT_ENABLE_REG: Interrupt Enable Register -->
            <register>
              <name>INT_ENABLE_REG</name>
              <description>Interrupt Enable Register</description>
              <addressOffset>0x0020</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- Int_enable: Interrupt Enable Register, enables appropriate channel interrupt -->
                <field>
                  <name>Int_enable</name>
                  <description>Interrupt Enable Register, enables appropriate channel interrupt</description>
                  <bitRange>[11:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- INT_SET_REG: Interrupt Set Register -->
            <register>
              <name>INT_SET_REG</name>
              <description>Interrupt Set Register</description>
              <addressOffset>0x0024</addressOffset>
              <size>32</size>
              <access>write-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- int_set: Interrupt Set Register, user can generate interrupt by writing '1' to the corresponding bit of this register -->
                <field>
                  <name>int_set</name>
                  <description>Interrupt Set Register, user can generate interrupt by writing '1' to the corresponding bit of this register</description>
                  <bitRange>[11:0]</bitRange>
                  <access>write-only</access>
                </field>

              </fields>
           </register>


          </registers>
    </peripheral>
    <peripheral>
          <name>i3c_m_inst</name>
          <version>3.7.0</version>
          <baseAddress>0x00010400</baseAddress>
          <groupName>i3c_controller</groupName>
          <description></description>

          <addressBlock>
            <offset>0x0</offset>
            <size>0x00000400</size>
            <usage>registers</usage>
          </addressBlock>

          <registers>
                <!-- CLKDIV: System Clock Divider Register -->
            <register>
              <name>CLKDIV</name>
              <description>System Clock Divider Register</description>
              <addressOffset>0x0004</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- sys_clk_div: Indicates the clock pulse width of the generated SCL in terms of number of system clock (clk_i) cycles -->
                <field>
                  <name>sys_clk_div</name>
                  <description>Indicates the clock pulse width of the generated SCL in terms of number of system clock (clk_i) cycles</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- MSTCFG0: Controller Configuration 0 Register  -->
            <register>
              <name>MSTCFG0</name>
              <description>Controller Configuration 0 Register </description>
              <addressOffset>0x0008</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- auto_assert_role: Applicable only when Secondary Controller is enabled. 1 - Enable auto assert role. Automatically assert role when taking over as the new Active Controller after GETACCCR CCC. The device will send the broadcast address {0x7E, W} to assert its role. 0 - Disable auto assert role. Device will wait until other device pull the SDA down or if user writes to Tx FIFO. -->
                <field>
                  <name>auto_assert_role</name>
                  <description>Applicable only when Secondary Controller is enabled. 1 - Enable auto assert role. Automatically assert role when taking over as the new Active Controller after GETACCCR CCC. The device will send the broadcast address {0x7E, W} to assert its role. 0 - Disable auto assert role. Device will wait until other device pull the SDA down or if user writes to Tx FIFO.</description>
                  <bitRange>[6:6]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- ibi_auto_resp: Applicable only when Secondary Controller is enabled. 1 - Always NAK the IBI request and continue the current transfer until Tx FIFO is empty. 0 - Pause the SCL on low during ACK phase and wait for the user to program the appropriate response. See registers ibi_rcnt and ibi_resp. -->
                <field>
                  <name>ibi_auto_resp</name>
                  <description>Applicable only when Secondary Controller is enabled. 1 - Always NAK the IBI request and continue the current transfer until Tx FIFO is empty. 0 - Pause the SCL on low during ACK phase and wait for the user to program the appropriate response. See registers ibi_rcnt and ibi_resp.</description>
                  <bitRange>[5:5]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- ignore_cmd_done: 1 - The I3C controller will continue to process the contents of the Tx FIFO until it is empty. 0 - The I3C controller will stop after transferring 1 packet and the user will have to set/program the start register again to resume the transfer. -->
                <field>
                  <name>ignore_cmd_done</name>
                  <description>1 - The I3C controller will continue to process the contents of the Tx FIFO until it is empty. 0 - The I3C controller will stop after transferring 1 packet and the user will have to set/program the start register again to resume the transfer.</description>
                  <bitRange>[4:4]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- i2c_mode_allowed: 1 - Allows transferring I2C frames. 0 - Only I3C frames can be transferred. -->
                <field>
                  <name>i2c_mode_allowed</name>
                  <description>1 - Allows transferring I2C frames. 0 - Only I3C frames can be transferred.</description>
                  <bitRange>[3:3]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- ignore_rcvd_nak: 1 - The IP will continue to process the contents of the Tx FIFO (until empty) even if a NAK was received. 0 - The I3C controller will stop after receiving a NAK and the user will have to set/program the start register again to resume the transfer. -->
                <field>
                  <name>ignore_rcvd_nak</name>
                  <description>1 - The IP will continue to process the contents of the Tx FIFO (until empty) even if a NAK was received. 0 - The I3C controller will stop after receiving a NAK and the user will have to set/program the start register again to resume the transfer.</description>
                  <bitRange>[2:2]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- en_daa_uid_in_rxfifo: During dynamic address assignment, the I3C targets will broadcast their unique IDs (48bits) including BCR and DCR as part of the arbitration process. 1 - The unique IDs, BCR, and DCR will be stored in Rx FIFO and can be read by user. 0 - It will be discarded. -->
                <field>
                  <name>en_daa_uid_in_rxfifo</name>
                  <description>During dynamic address assignment, the I3C targets will broadcast their unique IDs (48bits) including BCR and DCR as part of the arbitration process. 1 - The unique IDs, BCR, and DCR will be stored in Rx FIFO and can be read by user. 0 - It will be discarded.</description>
                  <bitRange>[1:1]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- i3c_priv_rw_no_7e: 1 - Starts the private write/read access with dynamic address instead of I3C broadcast address 0x7E. 0 - The private access will start with 0x7E address followed by repeated start (Sr) then the target's dynamic address. -->
                <field>
                  <name>i3c_priv_rw_no_7e</name>
                  <description>1 - Starts the private write/read access with dynamic address instead of I3C broadcast address 0x7E. 0 - The private access will start with 0x7E address followed by repeated start (Sr) then the target's dynamic address.</description>
                  <bitRange>[0:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- ODTIMER   : Open-Drain Timer. -->
            <register>
              <name>ODTIMER   </name>
              <description>Open-Drain Timer.</description>
              <addressOffset>0x000C</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- od_timer: Used for generation of SCL clock in open drain mode of I3C transaction. This setting indicates the clock pulse width of open drain SCL clock in terms of number of normal SCL clock cycles as generated using sys_clk_div setting. (0 - 1 SCL clock cycle. Use normal SCL clock generated using the System Clock divider., 1 - 2 SCL clock cycles, ..., 15 - 16 SCL clock cycles) -->
                <field>
                  <name>od_timer</name>
                  <description>Used for generation of SCL clock in open drain mode of I3C transaction. This setting indicates the clock pulse width of open drain SCL clock in terms of number of normal SCL clock cycles as generated using sys_clk_div setting. (0 - 1 SCL clock cycle. Use normal SCL clock generated using the System Clock divider., 1 - 2 SCL clock cycles, ..., 15 - 16 SCL clock cycles)</description>
                  <bitRange>[3:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- I2C_DIV: I2C Clock Divider Register. Applicable only when user enabled the use of internal dividers in IP Generation GUI. -->
            <register>
              <name>I2C_DIV</name>
              <description>I2C Clock Divider Register. Applicable only when user enabled the use of internal dividers in IP Generation GUI.</description>
              <addressOffset>0x0010</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- i2c_clkdiv: Used for generation of SCL clock in I2C mode. This setting indicates the clock pulse width of SCL in terms of number of system clock (clk_i) cycles. (0 - 1 clk_i clock cycle, 1 - 2 clk_i clock cycles, ..., 255 - 256 clk_i clock cycles) -->
                <field>
                  <name>i2c_clkdiv</name>
                  <description>Used for generation of SCL clock in I2C mode. This setting indicates the clock pulse width of SCL in terms of number of system clock (clk_i) cycles. (0 - 1 clk_i clock cycle, 1 - 2 clk_i clock cycles, ..., 255 - 256 clk_i clock cycles)</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- SPUWPU: Pull Up Resistor Disable Register -->
            <register>
              <name>SPUWPU</name>
              <description>Pull Up Resistor Disable Register</description>
              <addressOffset>0x0014</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- scl_spu_n: When set to high, disables the strong pull up resistor in SCL. -->
                <field>
                  <name>scl_spu_n</name>
                  <description>When set to high, disables the strong pull up resistor in SCL.</description>
                  <bitRange>[3:3]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- scl_wpu_n: When set to high, disables the weak pull up resistor in SCL. -->
                <field>
                  <name>scl_wpu_n</name>
                  <description>When set to high, disables the weak pull up resistor in SCL.</description>
                  <bitRange>[2:2]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- sda_spu_n: When set to high, disables the strong pull up resistor in SDA. -->
                <field>
                  <name>sda_spu_n</name>
                  <description>When set to high, disables the strong pull up resistor in SDA.</description>
                  <bitRange>[1:1]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- sda_wpu_n: When set to high, disables the weak pull up resistor in SDA. -->
                <field>
                  <name>sda_wpu_n</name>
                  <description>When set to high, disables the weak pull up resistor in SDA.</description>
                  <bitRange>[0:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- HDRCFG0: HDR-DDR Mode Configuration. Applicable only when user enabled the HDR-DDR capability. -->
            <register>
              <name>HDRCFG0</name>
              <description>HDR-DDR Mode Configuration. Applicable only when user enabled the HDR-DDR capability.</description>
              <addressOffset>0x0018</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- no_crc_after_term: Applicable only when HDR-DDR capability is enabled. Configures the data transfer ending procedure. 1 - No CRC word follows early termination request. 0 - CRC word follows early termination request. -->
                <field>
                  <name>no_crc_after_term</name>
                  <description>Applicable only when HDR-DDR capability is enabled. Configures the data transfer ending procedure. 1 - No CRC word follows early termination request. 0 - CRC word follows early termination request.</description>
                  <bitRange>[2:2]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- en_wr_early_term: Applicable only when HDR-DDR capability is enabled. Configures the data transfer ending procedure. 1 - Enables write early termination request. 0 - Disables write early termination request. -->
                <field>
                  <name>en_wr_early_term</name>
                  <description>Applicable only when HDR-DDR capability is enabled. Configures the data transfer ending procedure. 1 - Enables write early termination request. 0 - Disables write early termination request.</description>
                  <bitRange>[1:1]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- en_wrcmd_acknak_cap: Applicable only when HDR-DDR capability is enabled. Configures the data transfer ending procedure. 1 - Enables ACK/NAK capability for write command. 0 - Disables ACK/NAK capability for write command. -->
                <field>
                  <name>en_wrcmd_acknak_cap</name>
                  <description>Applicable only when HDR-DDR capability is enabled. Configures the data transfer ending procedure. 1 - Enables ACK/NAK capability for write command. 0 - Disables ACK/NAK capability for write command.</description>
                  <bitRange>[0:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- SOFTRST: Soft Reset. -->
            <register>
              <name>SOFTRST</name>
              <description>Soft Reset.</description>
              <addressOffset>0x0020</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- ip_csr_rst: When set to high, resets the IP registers only. Auto-clear. -->
                <field>
                  <name>ip_csr_rst</name>
                  <description>When set to high, resets the IP registers only. Auto-clear.</description>
                  <bitRange>[4:4]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- ip_core_rst: When set to high, resets the I3C Controller only. Auto-clear. -->
                <field>
                  <name>ip_core_rst</name>
                  <description>When set to high, resets the I3C Controller only. Auto-clear.</description>
                  <bitRange>[3:3]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- tx_fifo_rst: When set to high, resets the Tx FIFO only. Auto-clear. -->
                <field>
                  <name>tx_fifo_rst</name>
                  <description>When set to high, resets the Tx FIFO only. Auto-clear.</description>
                  <bitRange>[2:2]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- rx_fifo_rst: When set to high, resets the Rx FIFO only. Auto-clear. -->
                <field>
                  <name>rx_fifo_rst</name>
                  <description>When set to high, resets the Rx FIFO only. Auto-clear.</description>
                  <bitRange>[1:1]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- ip_main_rst: When set to high, resets the whole IP including registers and FIFO. Auto-clear. -->
                <field>
                  <name>ip_main_rst</name>
                  <description>When set to high, resets the whole IP including registers and FIFO. Auto-clear.</description>
                  <bitRange>[0:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- TXSTART: Transmit Start Register -->
            <register>
              <name>TXSTART</name>
              <description>Transmit Start Register</description>
              <addressOffset>0x0044</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- tx_start: When set to high, the IP starts processing the contents of Tx FIFO. This register auto-clears when when a command is done or a NAK is received unless it is bypassed by ignore_cmd_done or ignore_rcvd_nak register setting in controller configuration 0 register. To continue with the transfer, user will have to set this to 1 again. -->
                <field>
                  <name>tx_start</name>
                  <description>When set to high, the IP starts processing the contents of Tx FIFO. This register auto-clears when when a command is done or a NAK is received unless it is bypassed by ignore_cmd_done or ignore_rcvd_nak register setting in controller configuration 0 register. To continue with the transfer, user will have to set this to 1 again.</description>
                  <bitRange>[0:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- SC_STAT: Secondary Controller Status Info Register. Applicable only when user enabled the Secondary Controller in IP Generation GUI. -->
            <register>
              <name>SC_STAT</name>
              <description>Secondary Controller Status Info Register. Applicable only when user enabled the Secondary Controller in IP Generation GUI.</description>
              <addressOffset>0x0054</addressOffset>
              <size>32</size>
              <access>read-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- get_acccr_result: This status is the result of the GETACCCR command. This information is valid only if the interrupt status register get_acccr_done is asserted. Clear when interrupt status get_acccr_done is cleared. (0 - Successful controller handoff, 1 - ControllerHandoff failed) -->
                <field>
                  <name>get_acccr_result</name>
                  <description>This status is the result of the GETACCCR command. This information is valid only if the interrupt status register get_acccr_done is asserted. Clear when interrupt status get_acccr_done is cleared. (0 - Successful controller handoff, 1 - ControllerHandoff failed)</description>
                  <bitRange>[2:2]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- get_acccr_started: Indicates that the device has started/sent GETACCCR CCC. Clear when interrupt status get_acccr_done is cleared. 1 - Started GETACCCR CCC, 0 - No GETACCCR CCC -->
                <field>
                  <name>get_acccr_started</name>
                  <description>Indicates that the device has started/sent GETACCCR CCC. Clear when interrupt status get_acccr_done is cleared. 1 - Started GETACCCR CCC, 0 - No GETACCCR CCC</description>
                  <bitRange>[1:1]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- active_controller: Indicates the current role of this device. The default value of this register takes the Device Role GUI parameter setting. If user selected Primary Controller, then the default value will be (1) Active Controller, otherwise it will be acting as a Target (0). The value of this register may change if there is a successful controller handoff or if user forced it by programming the Set Device Role register. 1 - Active Controller
0 - Target -->
                <field>
                  <name>active_controller</name>
                  <description>Indicates the current role of this device. The default value of this register takes the Device Role GUI parameter setting. If user selected Primary Controller, then the default value will be (1) Active Controller, otherwise it will be acting as a Target (0). The value of this register may change if there is a successful controller handoff or if user forced it by programming the Set Device Role register. 1 - Active Controller
0 - Target</description>
                  <bitRange>[0:0]</bitRange>
                  <access>read-only</access>
                </field>

              </fields>
           </register>

      <!-- SC_ROLE: Set Device Role register. Applicable only when user enabled the Secondary Controller in IP Generation GUI. -->
            <register>
              <name>SC_ROLE</name>
              <description>Set Device Role register. Applicable only when user enabled the Secondary Controller in IP Generation GUI.</description>
              <addressOffset>0x0058</addressOffset>
              <size>32</size>
              <access>read-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- set_device_role: This status is the result of the GETACCCR command. This information is valid only if the interrupt status register get_acccr_done is asserted. Clear when interrupt status get_acccr_done is cleared. (0 - Successful controller handoff, 1 - ControllerHandoff failed) -->
                <field>
                  <name>set_device_role</name>
                  <description>This status is the result of the GETACCCR command. This information is valid only if the interrupt status register get_acccr_done is asserted. Clear when interrupt status get_acccr_done is cleared. (0 - Successful controller handoff, 1 - ControllerHandoff failed)</description>
                  <bitRange>[2:2]</bitRange>
                  <access>read-only</access>
                </field>

              </fields>
           </register>

      <!-- SC_TIMER0: Secondary Controller Timeout Register. Applicable only when user enabled the Secondary Controller in IP Generation GUI. -->
            <register>
              <name>SC_TIMER0</name>
              <description>Secondary Controller Timeout Register. Applicable only when user enabled the Secondary Controller in IP Generation GUI.</description>
              <addressOffset>0x005C</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- crh_timeout0: Controller role handoff timeout value. This is the number of system clock (clk_i) cycles.
The default value is equivalent to 100us (40ns * 2500). This timeout value is used during controller handoff procedure when the former active controller confirms if the new active controller will assert its controller role. -->
                <field>
                  <name>crh_timeout0</name>
                  <description>Controller role handoff timeout value. This is the number of system clock (clk_i) cycles.
The default value is equivalent to 100us (40ns * 2500). This timeout value is used during controller handoff procedure when the former active controller confirms if the new active controller will assert its controller role.</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- SC_TIMER1: Secondary Controller Timeout Register. Applicable only when user enabled the Secondary Controller in IP Generation GUI. -->
            <register>
              <name>SC_TIMER1</name>
              <description>Secondary Controller Timeout Register. Applicable only when user enabled the Secondary Controller in IP Generation GUI.</description>
              <addressOffset>0x0060</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- crh_timeout1: Controller role handoff timeout value. This is the number of system clock (clk_i) cycles.
The default value is equivalent to 100us (40ns * 2500). This timeout value is used during controller handoff procedure when the former active controller confirms if the new active controller will assert its controller role. -->
                <field>
                  <name>crh_timeout1</name>
                  <description>Controller role handoff timeout value. This is the number of system clock (clk_i) cycles.
The default value is equivalent to 100us (40ns * 2500). This timeout value is used during controller handoff procedure when the former active controller confirms if the new active controller will assert its controller role.</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- SC_TIMER2: Secondary Controller Timeout Register. Applicable only when user enabled the Secondary Controller in IP Generation GUI. -->
            <register>
              <name>SC_TIMER2</name>
              <description>Secondary Controller Timeout Register. Applicable only when user enabled the Secondary Controller in IP Generation GUI.</description>
              <addressOffset>0x0064</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- crh_timeout2: Controller role handoff timeout value. This is the number of system clock (clk_i) cycles.
The default value is equivalent to 100us (40ns * 2500). This timeout value is used during controller handoff procedure when the former active controller confirms if the new active controller will assert its controller role. -->
                <field>
                  <name>crh_timeout2</name>
                  <description>Controller role handoff timeout value. This is the number of system clock (clk_i) cycles.
The default value is equivalent to 100us (40ns * 2500). This timeout value is used during controller handoff procedure when the former active controller confirms if the new active controller will assert its controller role.</description>
                  <bitRange>[3:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- DA_ACKED: Dynamic Address ACKed Counter. -->
            <register>
              <name>DA_ACKED</name>
              <description>Dynamic Address ACKed Counter.</description>
              <addressOffset>0x0070</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- num_da_acked: Running counter that indicates the number of dynamic address that was acknowledged during Enter DAA command. This counter will reset to 0 after writing all 1's. -->
                <field>
                  <name>num_da_acked</name>
                  <description>Running counter that indicates the number of dynamic address that was acknowledged during Enter DAA command. This counter will reset to 0 after writing all 1's.</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- IBIRCNT: IBI Read Count Register. Applicable only when in-band interrupt capability is enabled. -->
            <register>
              <name>IBIRCNT</name>
              <description>IBI Read Count Register. Applicable only when in-band interrupt capability is enabled.</description>
              <addressOffset>0x0074</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- ibi_rcnt: Indicates the number of bytes to read from target during IBI. This should be set depending on the target's setting. Set this register to 0 when responding to Hot Join or Secondary Controller interrupt. -->
                <field>
                  <name>ibi_rcnt</name>
                  <description>Indicates the number of bytes to read from target during IBI. This should be set depending on the target's setting. Set this register to 0 when responding to Hot Join or Secondary Controller interrupt.</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- IBIRESP: IBI Response Register. Applicable only when in-band interrupt capability is enabled. -->
            <register>
              <name>IBIRESP</name>
              <description>IBI Response Register. Applicable only when in-band interrupt capability is enabled.</description>
              <addressOffset>0x0078</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- ibi_resp: This will be the response of the I3C controller to the IBI or Hot Join request. Write to this register will trigger the IP to send the indicated response. 0 - ACK the IBI or Hot Join, 1 - NAK the IBI or Hot Join -->
                <field>
                  <name>ibi_resp</name>
                  <description>This will be the response of the I3C controller to the IBI or Hot Join request. Write to this register will trigger the IP to send the indicated response. 0 - ACK the IBI or Hot Join, 1 - NAK the IBI or Hot Join</description>
                  <bitRange>[0:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- IBIADDR: IBI Address Register. Applicable only when in-band interrupt capability is enabled. -->
            <register>
              <name>IBIADDR</name>
              <description>IBI Address Register. Applicable only when in-band interrupt capability is enabled.</description>
              <addressOffset>0x007C</addressOffset>
              <size>32</size>
              <access>read-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- ibi_addr: This shows the address of the I3C Target or Secondary Controller that requested the IBI. If the interrupt is Hot Join, this will show the reserved target address 7'h02.  -->
                <field>
                  <name>ibi_addr</name>
                  <description>This shows the address of the I3C Target or Secondary Controller that requested the IBI. If the interrupt is Hot Join, this will show the reserved target address 7'h02. </description>
                  <bitRange>[7:1]</bitRange>
                  <access>read-only</access>
                </field>

              </fields>
           </register>

      <!-- INTSTAT0: Interrupt Status 0 Register. When high, it indicates an event and when the corresponding interrupt enable bit is enabled, it will cause the assertion of interrupt port (int_o). -->
            <register>
              <name>INTSTAT0</name>
              <description>Interrupt Status 0 Register. When high, it indicates an event and when the corresponding interrupt enable bit is enabled, it will cause the assertion of interrupt port (int_o).</description>
              <addressOffset>0x0080</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- rcvd_slv_nak: When set to high, it indicates that a NAK was received. Clear on write of 1. -->
                <field>
                  <name>rcvd_slv_nak</name>
                  <description>When set to high, it indicates that a NAK was received. Clear on write of 1.</description>
                  <bitRange>[7:7]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- command_done: When set to high, it indicates that a command has been sent (Private Write/Read or CCC). Clear on write of 1. -->
                <field>
                  <name>command_done</name>
                  <description>When set to high, it indicates that a command has been sent (Private Write/Read or CCC). Clear on write of 1.</description>
                  <bitRange>[6:6]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- rcvd_sec_ibi: When set, it indicates that Secondary Controller interrupt is received. Clear on write of 1. -->
                <field>
                  <name>rcvd_sec_ibi</name>
                  <description>When set, it indicates that Secondary Controller interrupt is received. Clear on write of 1.</description>
                  <bitRange>[5:5]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- rcvd_ibi: When set, it indicates that In-band interrupt is received. Clear on write of 1. -->
                <field>
                  <name>rcvd_ibi</name>
                  <description>When set, it indicates that In-band interrupt is received. Clear on write of 1.</description>
                  <bitRange>[4:4]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- rcvd_hot_join: When set to high, it indicates that Hot Join interrupt is received. Clear on write of 1. -->
                <field>
                  <name>rcvd_hot_join</name>
                  <description>When set to high, it indicates that Hot Join interrupt is received. Clear on write of 1.</description>
                  <bitRange>[3:3]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- tx_fifo_full: When set to high, it indicates that Tx FIFO is full. Clear on write of 1. -->
                <field>
                  <name>tx_fifo_full</name>
                  <description>When set to high, it indicates that Tx FIFO is full. Clear on write of 1.</description>
                  <bitRange>[2:2]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- rx_fifo_not_empty: When set to high, it indicates that Rx FIFO is not empty. Clear on write of 1. -->
                <field>
                  <name>rx_fifo_not_empty</name>
                  <description>When set to high, it indicates that Rx FIFO is not empty. Clear on write of 1.</description>
                  <bitRange>[1:1]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- rd_cmd_done: When set to high, it indicates that a private read is done and all requested data specified by length are available in the Rx FIFO. Clear on write of 1. -->
                <field>
                  <name>rd_cmd_done</name>
                  <description>When set to high, it indicates that a private read is done and all requested data specified by length are available in the Rx FIFO. Clear on write of 1.</description>
                  <bitRange>[0:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- INTSET0: Interrupt Set 0 Register. This is a dummy register that is used to test the assertion of interrupt status. When set to high, it triggers the corresponding interrupt status 0 signal. -->
            <register>
              <name>INTSET0</name>
              <description>Interrupt Set 0 Register. This is a dummy register that is used to test the assertion of interrupt status. When set to high, it triggers the corresponding interrupt status 0 signal.</description>
              <addressOffset>0x0084</addressOffset>
              <size>32</size>
              <access>write-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- rcvd_slv_nak_set: When set to high, it triggers the corresponding interrupt status 0 signal. -->
                <field>
                  <name>rcvd_slv_nak_set</name>
                  <description>When set to high, it triggers the corresponding interrupt status 0 signal.</description>
                  <bitRange>[7:7]</bitRange>
                  <access>write-only</access>
                </field>
            <!-- command_done_set: When set to high, it triggers the corresponding interrupt status 0 signal. -->
                <field>
                  <name>command_done_set</name>
                  <description>When set to high, it triggers the corresponding interrupt status 0 signal.</description>
                  <bitRange>[6:6]</bitRange>
                  <access>write-only</access>
                </field>
            <!-- rcvd_sec_ibi_set: When set to high, it triggers the corresponding interrupt status 0 signal. -->
                <field>
                  <name>rcvd_sec_ibi_set</name>
                  <description>When set to high, it triggers the corresponding interrupt status 0 signal.</description>
                  <bitRange>[5:5]</bitRange>
                  <access>write-only</access>
                </field>
            <!-- rcvd_ibi_set: When set to high, it triggers the corresponding interrupt status 0 signal. -->
                <field>
                  <name>rcvd_ibi_set</name>
                  <description>When set to high, it triggers the corresponding interrupt status 0 signal.</description>
                  <bitRange>[4:4]</bitRange>
                  <access>write-only</access>
                </field>
            <!-- rcvd_hot_join_set: When set to high, it triggers the corresponding interrupt status 0 signal. -->
                <field>
                  <name>rcvd_hot_join_set</name>
                  <description>When set to high, it triggers the corresponding interrupt status 0 signal.</description>
                  <bitRange>[3:3]</bitRange>
                  <access>write-only</access>
                </field>
            <!-- tx_fifo_full_set: When set to high, it triggers the corresponding interrupt status 0 signal. -->
                <field>
                  <name>tx_fifo_full_set</name>
                  <description>When set to high, it triggers the corresponding interrupt status 0 signal.</description>
                  <bitRange>[2:2]</bitRange>
                  <access>write-only</access>
                </field>
            <!-- rx_fifo_not_empty_set: When set to high, it triggers the corresponding interrupt status 0 signal. -->
                <field>
                  <name>rx_fifo_not_empty_set</name>
                  <description>When set to high, it triggers the corresponding interrupt status 0 signal.</description>
                  <bitRange>[1:1]</bitRange>
                  <access>write-only</access>
                </field>
            <!-- rd_cmd_done_set: When set to high, it triggers the corresponding interrupt status 0 signal. -->
                <field>
                  <name>rd_cmd_done_set</name>
                  <description>When set to high, it triggers the corresponding interrupt status 0 signal.</description>
                  <bitRange>[0:0]</bitRange>
                  <access>write-only</access>
                </field>

              </fields>
           </register>

      <!-- INTENA0: Interrupt Enable 0 Register. When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o). -->
            <register>
              <name>INTENA0</name>
              <description>Interrupt Enable 0 Register. When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o).</description>
              <addressOffset>0x0088</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- rcvd_slv_nak_en: When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o). -->
                <field>
                  <name>rcvd_slv_nak_en</name>
                  <description>When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o).</description>
                  <bitRange>[7:7]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- command_done_en: When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o). -->
                <field>
                  <name>command_done_en</name>
                  <description>When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o).</description>
                  <bitRange>[6:6]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- rcvd_sec_ibi_en: When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o). -->
                <field>
                  <name>rcvd_sec_ibi_en</name>
                  <description>When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o).</description>
                  <bitRange>[5:5]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- rcvd_ibi_en: When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o). -->
                <field>
                  <name>rcvd_ibi_en</name>
                  <description>When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o).</description>
                  <bitRange>[4:4]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- rcvd_hot_join_en: When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o). -->
                <field>
                  <name>rcvd_hot_join_en</name>
                  <description>When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o).</description>
                  <bitRange>[3:3]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- tx_fifo_full_en: When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o). -->
                <field>
                  <name>tx_fifo_full_en</name>
                  <description>When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o).</description>
                  <bitRange>[2:2]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- rx_fifo_not_empty_en: When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o). -->
                <field>
                  <name>rx_fifo_not_empty_en</name>
                  <description>When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o).</description>
                  <bitRange>[1:1]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- rd_cmd_done_en: When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o). -->
                <field>
                  <name>rd_cmd_done_en</name>
                  <description>When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o).</description>
                  <bitRange>[0:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- INTSTAT1: Interrupt Status 1 Register. When high, it indicates an event and when the corresponding interrupt enable bit is enabled, it will cause the assertion of interrupt port (int_o). -->
            <register>
              <name>INTSTAT1</name>
              <description>Interrupt Status 1 Register. When high, it indicates an event and when the corresponding interrupt enable bit is enabled, it will cause the assertion of interrupt port (int_o).</description>
              <addressOffset>0x0090</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- rx_fifo_full: When set to high, it indicates that Rx FIFO is full. Clear on write of 1. -->
                <field>
                  <name>rx_fifo_full</name>
                  <description>When set to high, it indicates that Rx FIFO is full. Clear on write of 1.</description>
                  <bitRange>[5:5]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- crh_timeout_expired: Applicable only when user enabled the Secondary Controller in IP Generation GUI. When set to high, it indicates that the controller handoff has failed due to the new controller failing to assert its role within the specified timeout value in Secondary Controller Timeout register. This means that this device will remain as active controller. Clear on write of 1. -->
                <field>
                  <name>crh_timeout_expired</name>
                  <description>Applicable only when user enabled the Secondary Controller in IP Generation GUI. When set to high, it indicates that the controller handoff has failed due to the new controller failing to assert its role within the specified timeout value in Secondary Controller Timeout register. This means that this device will remain as active controller. Clear on write of 1.</description>
                  <bitRange>[4:4]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- get_acccr_done: Applicable only when user enabled the Secondary Controller in IP Generation GUI. When set to high, it indicates that GETACCCR CCC was done and the result of this command is available in the secondary controller status info register. Clear on write of 1. -->
                <field>
                  <name>get_acccr_done</name>
                  <description>Applicable only when user enabled the Secondary Controller in IP Generation GUI. When set to high, it indicates that GETACCCR CCC was done and the result of this command is available in the secondary controller status info register. Clear on write of 1.</description>
                  <bitRange>[3:3]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- ibi_rd_done: When set to high, it indicates IBI payload was received and IBI read transaction has been terminated. Clear on write of 1. -->
                <field>
                  <name>ibi_rd_done</name>
                  <description>When set to high, it indicates IBI payload was received and IBI read transaction has been terminated. Clear on write of 1.</description>
                  <bitRange>[2:2]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- wr_early_term: When set to high, it indicates that I2C private write data was not completely transferred due to the target terminating it with NAK. Clear on write of 1. -->
                <field>
                  <name>wr_early_term</name>
                  <description>When set to high, it indicates that I2C private write data was not completely transferred due to the target terminating it with NAK. Clear on write of 1.</description>
                  <bitRange>[1:1]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- rd_early_term: When set to high, it indicates that a private read is done due to target terminating with T bit==0 and the read data received is less than what was requested. Clear on write of 1. -->
                <field>
                  <name>rd_early_term</name>
                  <description>When set to high, it indicates that a private read is done due to target terminating with T bit==0 and the read data received is less than what was requested. Clear on write of 1.</description>
                  <bitRange>[0:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- INTSET1: Interrupt Set 1 Register. This is a dummy register that is used to test the assertion of interrupt status. When set to high, it triggers the corresponding interrupt status 1 signal. -->
            <register>
              <name>INTSET1</name>
              <description>Interrupt Set 1 Register. This is a dummy register that is used to test the assertion of interrupt status. When set to high, it triggers the corresponding interrupt status 1 signal.</description>
              <addressOffset>0x0094</addressOffset>
              <size>32</size>
              <access>write-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- rx_fifo_full_set: When set to high, it triggers the corresponding interrupt status 1 signal. -->
                <field>
                  <name>rx_fifo_full_set</name>
                  <description>When set to high, it triggers the corresponding interrupt status 1 signal.</description>
                  <bitRange>[5:5]</bitRange>
                  <access>write-only</access>
                </field>
            <!-- crh_timeout_expired_set: When set to high, it triggers the corresponding interrupt status 1 signal. -->
                <field>
                  <name>crh_timeout_expired_set</name>
                  <description>When set to high, it triggers the corresponding interrupt status 1 signal.</description>
                  <bitRange>[4:4]</bitRange>
                  <access>write-only</access>
                </field>
            <!-- get_acccr_done_set: When set to high, it triggers the corresponding interrupt status 1 signal. -->
                <field>
                  <name>get_acccr_done_set</name>
                  <description>When set to high, it triggers the corresponding interrupt status 1 signal.</description>
                  <bitRange>[3:3]</bitRange>
                  <access>write-only</access>
                </field>
            <!-- ibi_rd_done_set: When set to high, it triggers the corresponding interrupt status 1 signal. -->
                <field>
                  <name>ibi_rd_done_set</name>
                  <description>When set to high, it triggers the corresponding interrupt status 1 signal.</description>
                  <bitRange>[2:2]</bitRange>
                  <access>write-only</access>
                </field>
            <!-- wr_early_term_set: When set to high, it triggers the corresponding interrupt status 1 signal. -->
                <field>
                  <name>wr_early_term_set</name>
                  <description>When set to high, it triggers the corresponding interrupt status 1 signal.</description>
                  <bitRange>[1:1]</bitRange>
                  <access>write-only</access>
                </field>
            <!-- rd_early_term_set: When set to high, it triggers the corresponding interrupt status 1 signal. -->
                <field>
                  <name>rd_early_term_set</name>
                  <description>When set to high, it triggers the corresponding interrupt status 1 signal.</description>
                  <bitRange>[0:0]</bitRange>
                  <access>write-only</access>
                </field>

              </fields>
           </register>

      <!-- INTENA1: Interrupt Enable 1 Register.When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o). -->
            <register>
              <name>INTENA1</name>
              <description>Interrupt Enable 1 Register.When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o).</description>
              <addressOffset>0x0098</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- rx_fifo_full_en: When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o). -->
                <field>
                  <name>rx_fifo_full_en</name>
                  <description>When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o).</description>
                  <bitRange>[5:5]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- crh_timeout_expired_en: When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o). -->
                <field>
                  <name>crh_timeout_expired_en</name>
                  <description>When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o).</description>
                  <bitRange>[4:4]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- get_acccr_done_en: When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o). -->
                <field>
                  <name>get_acccr_done_en</name>
                  <description>When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o).</description>
                  <bitRange>[3:3]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- ibi_rd_done_en: When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o). -->
                <field>
                  <name>ibi_rd_done_en</name>
                  <description>When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o).</description>
                  <bitRange>[2:2]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- wr_early_term_en: When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o). -->
                <field>
                  <name>wr_early_term_en</name>
                  <description>When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o).</description>
                  <bitRange>[1:1]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- rd_early_term_en: When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o). -->
                <field>
                  <name>rd_early_term_en</name>
                  <description>When set to high, it enables the corresponding interrupt status 0 signal to cause the assertion of interrupt port signal (int_o).</description>
                  <bitRange>[0:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- BUSCOND: Bus Condition Debug Register -->
            <register>
              <name>BUSCOND</name>
              <description>Bus Condition Debug Register</description>
              <addressOffset>0x00A0</addressOffset>
              <size>32</size>
              <access>read-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- hdr_ddr_mode: When high, indicates that the bus is currently in HDR-DDR mode. Otherwise it is in SDR mode. -->
                <field>
                  <name>hdr_ddr_mode</name>
                  <description>When high, indicates that the bus is currently in HDR-DDR mode. Otherwise it is in SDR mode.</description>
                  <bitRange>[7:7]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- i3c_line_idle: When high, indicates that the bus state is in idle. This also implies that bus is free (SCL and SDA are both high). -->
                <field>
                  <name>i3c_line_idle</name>
                  <description>When high, indicates that the bus state is in idle. This also implies that bus is free (SCL and SDA are both high).</description>
                  <bitRange>[6:6]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- scl_oe: Shows the current value of the SCL output enable. 1 - SCL output is driven, 0 - SCL output is not driven -->
                <field>
                  <name>scl_oe</name>
                  <description>Shows the current value of the SCL output enable. 1 - SCL output is driven, 0 - SCL output is not driven</description>
                  <bitRange>[5:5]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- scl_o: Shows the current value of the SCL output generated by IP. 1 - SCL output is driven, 0 - SCL output is not driven -->
                <field>
                  <name>scl_o</name>
                  <description>Shows the current value of the SCL output generated by IP. 1 - SCL output is driven, 0 - SCL output is not driven</description>
                  <bitRange>[4:4]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- sda_wpu: Shows the current value of the SDA weak pull up control signal. 1 - weak pull up resistor is disabled, 0 - weak pull up resistor is enabled -->
                <field>
                  <name>sda_wpu</name>
                  <description>Shows the current value of the SDA weak pull up control signal. 1 - weak pull up resistor is disabled, 0 - weak pull up resistor is enabled</description>
                  <bitRange>[3:3]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- sda_spu: Shows the current value of the SDA strong pull up control signal. 1 - strong pull up resistor is disabled, 0 - strong pull up resistor is enabled -->
                <field>
                  <name>sda_spu</name>
                  <description>Shows the current value of the SDA strong pull up control signal. 1 - strong pull up resistor is disabled, 0 - strong pull up resistor is enabled</description>
                  <bitRange>[2:2]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- sda_oe: Shows the current value of the SDA output enable. 1 - SDA output is driven, 0 - SDA output is not driven -->
                <field>
                  <name>sda_oe</name>
                  <description>Shows the current value of the SDA output enable. 1 - SDA output is driven, 0 - SDA output is not driven</description>
                  <bitRange>[1:1]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- sda_o: Shows the current value of the SDA output generated by IP. -->
                <field>
                  <name>sda_o</name>
                  <description>Shows the current value of the SDA output generated by IP.</description>
                  <bitRange>[0:0]</bitRange>
                  <access>read-only</access>
                </field>

              </fields>
           </register>

      <!-- LASTNAKADR: Last NAKed Target Address -->
            <register>
              <name>LASTNAKADR</name>
              <description>Last NAKed Target Address</description>
              <addressOffset>0x00A4</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- tgt_addr: This shows the latest target address driven by the I3C Controller that receives a NAK response.  -->
                <field>
                  <name>tgt_addr</name>
                  <description>This shows the latest target address driven by the I3C Controller that receives a NAK response. </description>
                  <bitRange>[7:1]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- read1_write0: Indicates the transaction type either read (1) or write (0).  -->
                <field>
                  <name>read1_write0</name>
                  <description>Indicates the transaction type either read (1) or write (0). </description>
                  <bitRange>[0:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- LASTACKADR: Last ACKed Target Address -->
            <register>
              <name>LASTACKADR</name>
              <description>Last ACKed Target Address</description>
              <addressOffset>0x00A8</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- tgt_addr: This shows the latest target address driven by the I3C Controller that receives an ACK response.  -->
                <field>
                  <name>tgt_addr</name>
                  <description>This shows the latest target address driven by the I3C Controller that receives an ACK response. </description>
                  <bitRange>[7:1]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- read1_write0: Indicates the transaction type either read (1) or write (0).  -->
                <field>
                  <name>read1_write0</name>
                  <description>Indicates the transaction type either read (1) or write (0). </description>
                  <bitRange>[0:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- INTSTAT2: Interrupt Status 2 Register. When high, it indicates an event and when the corresponding interrupt enable bit is enabled, it will cause the assertion of interrupt port (int_o). -->
            <register>
              <name>INTSTAT2</name>
              <description>Interrupt Status 2 Register. When high, it indicates an event and when the corresponding interrupt enable bit is enabled, it will cause the assertion of interrupt port (int_o).</description>
              <addressOffset>0x00B0</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- hdr_rcvd_nak: Applicable only if HDR-DDR capable. When set to high, it indicates that a NAK was received. Clear on write of 1. -->
                <field>
                  <name>hdr_rcvd_nak</name>
                  <description>Applicable only if HDR-DDR capable. When set to high, it indicates that a NAK was received. Clear on write of 1.</description>
                  <bitRange>[7:7]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- hdr_command_done: Applicable only if HDR-DDR capable. When set to high, it indicates that a command has been sent (HDR Write/Read or CCC). Clear on write of 1. -->
                <field>
                  <name>hdr_command_done</name>
                  <description>Applicable only if HDR-DDR capable. When set to high, it indicates that a command has been sent (HDR Write/Read or CCC). Clear on write of 1.</description>
                  <bitRange>[6:6]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- hdr_par_error: Applicable only if HDR-DDR capable. When set, it indicates that Parity error is detected. Clear on write of 1. -->
                <field>
                  <name>hdr_par_error</name>
                  <description>Applicable only if HDR-DDR capable. When set, it indicates that Parity error is detected. Clear on write of 1.</description>
                  <bitRange>[4:4]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- hdr_crc_error: Applicable only if HDR-DDR capable. When set, it indicates that CRC error is detected. Clear on write of 1. -->
                <field>
                  <name>hdr_crc_error</name>
                  <description>Applicable only if HDR-DDR capable. When set, it indicates that CRC error is detected. Clear on write of 1.</description>
                  <bitRange>[3:3]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- hdr_rd_early_term: Applicable only if HDR-DDR capable. When set to high, it indicates that HDR read is done due to target terminating the transfer and the read data received is less than what was requested. Clear on write of 1. -->
                <field>
                  <name>hdr_rd_early_term</name>
                  <description>Applicable only if HDR-DDR capable. When set to high, it indicates that HDR read is done due to target terminating the transfer and the read data received is less than what was requested. Clear on write of 1.</description>
                  <bitRange>[2:2]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- hdr_wr_early_term: Applicable only if HDR-DDR capable. When set to high, it indicates that HDR write data was not completely transferred due to the target terminating the transfer. Clear on write of 1. -->
                <field>
                  <name>hdr_wr_early_term</name>
                  <description>Applicable only if HDR-DDR capable. When set to high, it indicates that HDR write data was not completely transferred due to the target terminating the transfer. Clear on write of 1.</description>
                  <bitRange>[1:1]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- hdr_rd_cmd_done: Applicable only if HDR-DDR capable. When set to high, it indicates that HDR read command is done and all requested data specified by length are available in the Rx FIFO. Clear on write of 1. -->
                <field>
                  <name>hdr_rd_cmd_done</name>
                  <description>Applicable only if HDR-DDR capable. When set to high, it indicates that HDR read command is done and all requested data specified by length are available in the Rx FIFO. Clear on write of 1.</description>
                  <bitRange>[0:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- INTSET2: Interrupt Set 2 Register. This is a dummy register that is used to test the assertion of interrupt status. When set to high, it triggers the corresponding interrupt status 2 signal. -->
            <register>
              <name>INTSET2</name>
              <description>Interrupt Set 2 Register. This is a dummy register that is used to test the assertion of interrupt status. When set to high, it triggers the corresponding interrupt status 2 signal.</description>
              <addressOffset>0x00B4</addressOffset>
              <size>32</size>
              <access>write-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- hdr_rcvd_nak_set: When set to high, it triggers the corresponding interrupt status 2 signal. -->
                <field>
                  <name>hdr_rcvd_nak_set</name>
                  <description>When set to high, it triggers the corresponding interrupt status 2 signal.</description>
                  <bitRange>[7:7]</bitRange>
                  <access>write-only</access>
                </field>
            <!-- hdr_command_done_set: When set to high, it triggers the corresponding interrupt status 2 signal. -->
                <field>
                  <name>hdr_command_done_set</name>
                  <description>When set to high, it triggers the corresponding interrupt status 2 signal.</description>
                  <bitRange>[6:6]</bitRange>
                  <access>write-only</access>
                </field>
            <!-- hdr_par_error_set: When set to high, it triggers the corresponding interrupt status 2 signal. -->
                <field>
                  <name>hdr_par_error_set</name>
                  <description>When set to high, it triggers the corresponding interrupt status 2 signal.</description>
                  <bitRange>[4:4]</bitRange>
                  <access>write-only</access>
                </field>
            <!-- hdr_crc_error_set: When set to high, it triggers the corresponding interrupt status 2 signal. -->
                <field>
                  <name>hdr_crc_error_set</name>
                  <description>When set to high, it triggers the corresponding interrupt status 2 signal.</description>
                  <bitRange>[3:3]</bitRange>
                  <access>write-only</access>
                </field>
            <!-- hdr_rd_early_term_set: When set to high, it triggers the corresponding interrupt status 2 signal. -->
                <field>
                  <name>hdr_rd_early_term_set</name>
                  <description>When set to high, it triggers the corresponding interrupt status 2 signal.</description>
                  <bitRange>[2:2]</bitRange>
                  <access>write-only</access>
                </field>
            <!-- hdr_wr_early_term_set: When set to high, it triggers the corresponding interrupt status 2 signal. -->
                <field>
                  <name>hdr_wr_early_term_set</name>
                  <description>When set to high, it triggers the corresponding interrupt status 2 signal.</description>
                  <bitRange>[1:1]</bitRange>
                  <access>write-only</access>
                </field>
            <!-- hdr_rd_cmd_done_set: When set to high, it triggers the corresponding interrupt status 2 signal. -->
                <field>
                  <name>hdr_rd_cmd_done_set</name>
                  <description>When set to high, it triggers the corresponding interrupt status 2 signal.</description>
                  <bitRange>[0:0]</bitRange>
                  <access>write-only</access>
                </field>

              </fields>
           </register>

      <!-- INTENA2: Interrupt Enable 2 Register. When set to high, it enables the corresponding interrupt status 2 signal to cause the assertion of interrupt port signal (int_o). -->
            <register>
              <name>INTENA2</name>
              <description>Interrupt Enable 2 Register. When set to high, it enables the corresponding interrupt status 2 signal to cause the assertion of interrupt port signal (int_o).</description>
              <addressOffset>0x00B8</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- hdr_rcvd_nak_en: When set to high, it enables the corresponding interrupt status 2 signal to cause the assertion of interrupt port signal (int_o). -->
                <field>
                  <name>hdr_rcvd_nak_en</name>
                  <description>When set to high, it enables the corresponding interrupt status 2 signal to cause the assertion of interrupt port signal (int_o).</description>
                  <bitRange>[7:7]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- hdr_command_done_en: When set to high, it enables the corresponding interrupt status 2 signal to cause the assertion of interrupt port signal (int_o). -->
                <field>
                  <name>hdr_command_done_en</name>
                  <description>When set to high, it enables the corresponding interrupt status 2 signal to cause the assertion of interrupt port signal (int_o).</description>
                  <bitRange>[6:6]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- hdr_par_error_en: When set to high, it enables the corresponding interrupt status 2 signal to cause the assertion of interrupt port signal (int_o). -->
                <field>
                  <name>hdr_par_error_en</name>
                  <description>When set to high, it enables the corresponding interrupt status 2 signal to cause the assertion of interrupt port signal (int_o).</description>
                  <bitRange>[4:4]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- hdr_crc_error_en: When set to high, it enables the corresponding interrupt status 2 signal to cause the assertion of interrupt port signal (int_o). -->
                <field>
                  <name>hdr_crc_error_en</name>
                  <description>When set to high, it enables the corresponding interrupt status 2 signal to cause the assertion of interrupt port signal (int_o).</description>
                  <bitRange>[3:3]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- hdr_rd_early_term_en: When set to high, it enables the corresponding interrupt status 2 signal to cause the assertion of interrupt port signal (int_o). -->
                <field>
                  <name>hdr_rd_early_term_en</name>
                  <description>When set to high, it enables the corresponding interrupt status 2 signal to cause the assertion of interrupt port signal (int_o).</description>
                  <bitRange>[2:2]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- hdr_wr_early_term_en: When set to high, it enables the corresponding interrupt status 2 signal to cause the assertion of interrupt port signal (int_o). -->
                <field>
                  <name>hdr_wr_early_term_en</name>
                  <description>When set to high, it enables the corresponding interrupt status 2 signal to cause the assertion of interrupt port signal (int_o).</description>
                  <bitRange>[1:1]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- hdr_rd_cmd_done_en: When set to high, it enables the corresponding interrupt status 2 signal to cause the assertion of interrupt port signal (int_o). -->
                <field>
                  <name>hdr_rd_cmd_done_en</name>
                  <description>When set to high, it enables the corresponding interrupt status 2 signal to cause the assertion of interrupt port signal (int_o).</description>
                  <bitRange>[0:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- TXFIFO: Tx FIFO Access -->
            <register>
              <name>TXFIFO</name>
              <description>Tx FIFO Access</description>
              <addressOffset>0x00C0</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- tx_fifo_data: This is a dummy register that is used to fill data to Tx FIFO. User will use this to send the packet frames to Tx FIFO through repeated write access to this dummy register. Reading this register would return the status of Tx FIFO not_empty flag. -->
                <field>
                  <name>tx_fifo_data</name>
                  <description>This is a dummy register that is used to fill data to Tx FIFO. User will use this to send the packet frames to Tx FIFO through repeated write access to this dummy register. Reading this register would return the status of Tx FIFO not_empty flag.</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- RXFIFO: Rx FIFO Access -->
            <register>
              <name>RXFIFO</name>
              <description>Rx FIFO Access</description>
              <addressOffset>0x0100</addressOffset>
              <size>32</size>
              <access>read-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- rx_fifo_data: This is a dummy register that is used to get the read data from Rx FIFO. The read data as a result of response from read request will be stored in Rx FIFO. User will use this to get the received data from Rx FIFO through repeated read access to this dummy register. User may want to check the interrupt status 0 register (bit[1]) first to determine if Rx FIFO is not empty. -->
                <field>
                  <name>rx_fifo_data</name>
                  <description>This is a dummy register that is used to get the read data from Rx FIFO. The read data as a result of response from read request will be stored in Rx FIFO. User will use this to get the received data from Rx FIFO through repeated read access to this dummy register. User may want to check the interrupt status 0 register (bit[1]) first to determine if Rx FIFO is not empty.</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-only</access>
                </field>

              </fields>
           </register>

      <!-- BCR: Target Bus Characteristics Register -->
            <register>
              <name>BCR</name>
              <description>Target Bus Characteristics Register</description>
              <addressOffset>0x0200</addressOffset>
              <size>32</size>
              <access>read-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- device_role: 2'b00 - I3C Target, 2'b01 - I3C Controller-capable (Not implemented in this IP), Others - Reserved for future definition by MIPI Alliance I3C WG -->
                <field>
                  <name>device_role</name>
                  <description>2'b00 - I3C Target, 2'b01 - I3C Controller-capable (Not implemented in this IP), Others - Reserved for future definition by MIPI Alliance I3C WG</description>
                  <bitRange>[7:6]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- advanced_caps: 0 - Does not support optional advanced capabilities., 1 - Supports optional advanced capabilities. When Target is configured with IBI capability and IBI payload, this is set to 1 for optional Pending Read MDB support. -->
                <field>
                  <name>advanced_caps</name>
                  <description>0 - Does not support optional advanced capabilities., 1 - Supports optional advanced capabilities. When Target is configured with IBI capability and IBI payload, this is set to 1 for optional Pending Read MDB support.</description>
                  <bitRange>[5:5]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- virtual_tgt_support: 0 - Is not a Virtual Target and does not expose other downstream Device(s), 1 - Is a Virtual Target, or exposes other downstream Device(s)  -->
                <field>
                  <name>virtual_tgt_support</name>
                  <description>0 - Is not a Virtual Target and does not expose other downstream Device(s), 1 - Is a Virtual Target, or exposes other downstream Device(s) </description>
                  <bitRange>[4:4]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- offline_capable: 0 - Device will always respond to I3C Bus commands, 1 - Device will not always respond to I3C Bus Commands -->
                <field>
                  <name>offline_capable</name>
                  <description>0 - Device will always respond to I3C Bus commands, 1 - Device will not always respond to I3C Bus Commands</description>
                  <bitRange>[3:3]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- ibi_payload: From IBI Payload Size attiribute. 0 - If IBI Payload Size  attribute is set to 0. No data bytes follow the IBI., 1 - If IBI Payload Size  attribute is set to greater than or equal to 1. One data byte (MDB) shall follow the accepted IBI, and additional data bytes may follow -->
                <field>
                  <name>ibi_payload</name>
                  <description>From IBI Payload Size attiribute. 0 - If IBI Payload Size  attribute is set to 0. No data bytes follow the IBI., 1 - If IBI Payload Size  attribute is set to greater than or equal to 1. One data byte (MDB) shall follow the accepted IBI, and additional data bytes may follow</description>
                  <bitRange>[2:2]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- ibi_capable: From IBI Capable attribute. 0 - Not capable., 1 -  Capable. -->
                <field>
                  <name>ibi_capable</name>
                  <description>From IBI Capable attribute. 0 - Not capable., 1 -  Capable.</description>
                  <bitRange>[1:1]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- max_d_speed_limit: From Maximum Data Speed Limitation attribute. 0 - No limitation., 1 - With limitation. Controller shall use GETMXDS CCC to get specific limitation from Target. -->
                <field>
                  <name>max_d_speed_limit</name>
                  <description>From Maximum Data Speed Limitation attribute. 0 - No limitation., 1 - With limitation. Controller shall use GETMXDS CCC to get specific limitation from Target.</description>
                  <bitRange>[0:0]</bitRange>
                  <access>read-only</access>
                </field>

              </fields>
           </register>

      <!-- DCR: Target Device Characteristics Register -->
            <register>
              <name>DCR</name>
              <description>Target Device Characteristics Register</description>
              <addressOffset>0x0204</addressOffset>
              <size>32</size>
              <access>read-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- dcr: Device ID set by User through DCR attribute. 255 available codes for describing the type of sensor or Device (e.g., accelerometer, gyroscope, composite Devices). Default value is 8'b0 for generic Device. -->
                <field>
                  <name>dcr</name>
                  <description>Device ID set by User through DCR attribute. 255 available codes for describing the type of sensor or Device (e.g., accelerometer, gyroscope, composite Devices). Default value is 8'b0 for generic Device.</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-only</access>
                </field>

              </fields>
           </register>

      <!-- DYN_ADDR: Assigned dynamic address and done flag -->
            <register>
              <name>DYN_ADDR</name>
              <description>Assigned dynamic address and done flag</description>
              <addressOffset>0x0208</addressOffset>
              <size>32</size>
              <access>read-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- daa_done: 0 - DA is not yet assigned or is reset by RSTDAA CCC.,1 - DA is assigned via ENTDAA, SETNEWDA, SETAASA or SETDASA CCC -->
                <field>
                  <name>daa_done</name>
                  <description>0 - DA is not yet assigned or is reset by RSTDAA CCC.,1 - DA is assigned via ENTDAA, SETNEWDA, SETAASA or SETDASA CCC</description>
                  <bitRange>[7:7]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- dyn_addr: Dynamic Address Assigned to I3C Target -->
                <field>
                  <name>dyn_addr</name>
                  <description>Dynamic Address Assigned to I3C Target</description>
                  <bitRange>[6:0]</bitRange>
                  <access>read-only</access>
                </field>

              </fields>
           </register>

      <!-- HJ_IBI_EN: Hot-Join and IBI enable from Controller via ENEC/DISEC CCC -->
            <register>
              <name>HJ_IBI_EN</name>
              <description>Hot-Join and IBI enable from Controller via ENEC/DISEC CCC</description>
              <addressOffset>0x020C</addressOffset>
              <size>32</size>
              <access>read-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- hj_enec: Hot-Join Enable by Controller. 0 - Target-initiated Hot-Join is not allowed on the I3C bus, 1 - Target-initiated Hot-Join is allowed on the I3C bus -->
                <field>
                  <name>hj_enec</name>
                  <description>Hot-Join Enable by Controller. 0 - Target-initiated Hot-Join is not allowed on the I3C bus, 1 - Target-initiated Hot-Join is allowed on the I3C bus</description>
                  <bitRange>[3:3]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- cr_enec: Controller Role Request Enable by Controller. 0 - Target-initiated Controller Role Request is not allowed on the I3C bus, 1 - Target-initiated Controller Role Request is allowed on the I3C bus -->
                <field>
                  <name>cr_enec</name>
                  <description>Controller Role Request Enable by Controller. 0 - Target-initiated Controller Role Request is not allowed on the I3C bus, 1 - Target-initiated Controller Role Request is allowed on the I3C bus</description>
                  <bitRange>[1:1]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- ibi_enec: IBI Enable by Controller. 0 - Target-initiated interrupts are not allowed on the I3C bus, 1 - Target-initiated interrupts are allowed on the I3C bus -->
                <field>
                  <name>ibi_enec</name>
                  <description>IBI Enable by Controller. 0 - Target-initiated interrupts are not allowed on the I3C bus, 1 - Target-initiated interrupts are allowed on the I3C bus</description>
                  <bitRange>[0:0]</bitRange>
                  <access>read-only</access>
                </field>

              </fields>
           </register>

      <!-- HJ_IBI_CAP: Hot-Join and IBI capability configured by User using attributes -->
            <register>
              <name>HJ_IBI_CAP</name>
              <description>Hot-Join and IBI capability configured by User using attributes</description>
              <addressOffset>0x0210</addressOffset>
              <size>32</size>
              <access>read-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- hj_cap: 0 - Target device is configured without Hot-Join Capability, 1 - Target device is configured with Hot-Join Capability -->
                <field>
                  <name>hj_cap</name>
                  <description>0 - Target device is configured without Hot-Join Capability, 1 - Target device is configured with Hot-Join Capability</description>
                  <bitRange>[3:3]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- cr_cap: 0 - Target device is configured without Secondary-Controller Capability, 1 - Target device is configured with Secondary-Controller Capability -->
                <field>
                  <name>cr_cap</name>
                  <description>0 - Target device is configured without Secondary-Controller Capability, 1 - Target device is configured with Secondary-Controller Capability</description>
                  <bitRange>[1:1]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- ibi_cap: 0 - Target device is configured without IBI Capability, 1 - Target device is configured with IBI Capability -->
                <field>
                  <name>ibi_cap</name>
                  <description>0 - Target device is configured without IBI Capability, 1 - Target device is configured with IBI Capability</description>
                  <bitRange>[0:0]</bitRange>
                  <access>read-only</access>
                </field>

              </fields>
           </register>

      <!-- HJ_IBI_REQ: Hot-Join and IBI request from User. -->
            <register>
              <name>HJ_IBI_REQ</name>
              <description>Hot-Join and IBI request from User.</description>
              <addressOffset>0x0214</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- hj_req: When set to High, Target will initiate Hot-Join request at the next valid opportunity. Reset to 0 when Hot-Join is done or disabled by the Controller. -->
                <field>
                  <name>hj_req</name>
                  <description>When set to High, Target will initiate Hot-Join request at the next valid opportunity. Reset to 0 when Hot-Join is done or disabled by the Controller.</description>
                  <bitRange>[3:3]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- cr_req: When set to High, Target will initiate Controller Role Request at the next valid opportunity. Reset to 0 when Controller Role Request is done or disabled by the Controller. -->
                <field>
                  <name>cr_req</name>
                  <description>When set to High, Target will initiate Controller Role Request at the next valid opportunity. Reset to 0 when Controller Role Request is done or disabled by the Controller.</description>
                  <bitRange>[1:1]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- ibi_req: When set to High, Target will initiate IBI at the next valid opportunity. Reset to 0 when IBI is done or disabled by the Controller. -->
                <field>
                  <name>ibi_req</name>
                  <description>When set to High, Target will initiate IBI at the next valid opportunity. Reset to 0 when IBI is done or disabled by the Controller.</description>
                  <bitRange>[0:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- HJ_IBI_RETRY: Number of retries for Hot-Join and IBI. -->
            <register>
              <name>HJ_IBI_RETRY</name>
              <description>Number of retries for Hot-Join and IBI.</description>
              <addressOffset>0x0218</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- hj_ibi_retry: Indicates number of times the Target retries Hot-Join or IBI when it is NACKed by the Controller. When set to 0, number of tries is not limited. -->
                <field>
                  <name>hj_ibi_retry</name>
                  <description>Indicates number of times the Target retries Hot-Join or IBI when it is NACKed by the Controller. When set to 0, number of tries is not limited.</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- MWL_MSB: Most significant byte of Maximum Write Length set by the Controller -->
            <register>
              <name>MWL_MSB</name>
              <description>Most significant byte of Maximum Write Length set by the Controller</description>
              <addressOffset>0x021C</addressOffset>
              <size>32</size>
              <access>read-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- mwl_msb: Most Significant Byte of maximum write length set by I3C Controller via SETMWL CCC. If SETMWL is greater than default value 512 (FIFO size), MWL will be set to 512. -->
                <field>
                  <name>mwl_msb</name>
                  <description>Most Significant Byte of maximum write length set by I3C Controller via SETMWL CCC. If SETMWL is greater than default value 512 (FIFO size), MWL will be set to 512.</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-only</access>
                </field>

              </fields>
           </register>

      <!-- MWL_LSB: Least significant byte of Maximum Write Length set by the Controller -->
            <register>
              <name>MWL_LSB</name>
              <description>Least significant byte of Maximum Write Length set by the Controller</description>
              <addressOffset>0x0220</addressOffset>
              <size>32</size>
              <access>read-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- mwl_lsb: Least Significant Byte of maximum write length set by I3C Controller via SETMWL CCC. If SETMWL is greater than default value 512 (FIFO size), MWL will be set to 512. -->
                <field>
                  <name>mwl_lsb</name>
                  <description>Least Significant Byte of maximum write length set by I3C Controller via SETMWL CCC. If SETMWL is greater than default value 512 (FIFO size), MWL will be set to 512.</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-only</access>
                </field>

              </fields>
           </register>

      <!-- MRL_MSB: Most significant byte of Maximum Read Length set by the Controller -->
            <register>
              <name>MRL_MSB</name>
              <description>Most significant byte of Maximum Read Length set by the Controller</description>
              <addressOffset>0x0224</addressOffset>
              <size>32</size>
              <access>read-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- mrl_msb: Most Significant Byte of maximum read length set by I3C Controller via SETMRL CCC. If SETMRL is greater than default value 512 (FIFO size), MRL will be set to 512. -->
                <field>
                  <name>mrl_msb</name>
                  <description>Most Significant Byte of maximum read length set by I3C Controller via SETMRL CCC. If SETMRL is greater than default value 512 (FIFO size), MRL will be set to 512.</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-only</access>
                </field>

              </fields>
           </register>

      <!-- MRL_LSB: Least significant byte of Maximum Read Length set by the Controller -->
            <register>
              <name>MRL_LSB</name>
              <description>Least significant byte of Maximum Read Length set by the Controller</description>
              <addressOffset>0x0228</addressOffset>
              <size>32</size>
              <access>read-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- mrl_lsb: Least Significant Byte of maximum read length set by I3C Controller via SETMRL CCC. If SETMRL is greater than default value 512 (FIFO size), MRL will be set to 512. -->
                <field>
                  <name>mrl_lsb</name>
                  <description>Least Significant Byte of maximum read length set by I3C Controller via SETMRL CCC. If SETMRL is greater than default value 512 (FIFO size), MRL will be set to 512.</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-only</access>
                </field>

              </fields>
           </register>

      <!-- MAX_IBI_PAYLD: Maximum IBI Payload Size set by the Controller. Applicable only when Target is configured with IBI capability and IBI payload is set to greater than or equal to 1.  -->
            <register>
              <name>MAX_IBI_PAYLD</name>
              <description>Maximum IBI Payload Size set by the Controller. Applicable only when Target is configured with IBI capability and IBI payload is set to greater than or equal to 1. </description>
              <addressOffset>0x022C</addressOffset>
              <size>32</size>
              <access>read-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- max_ibi_payld: Maximum IBI Payload set by I3C Controller via SETMRL CCC. If value is greater than FIFO size, register will be set to FIFO size. Unlimited payload size is not supported in this IP. -->
                <field>
                  <name>max_ibi_payld</name>
                  <description>Maximum IBI Payload set by I3C Controller via SETMRL CCC. If value is greater than FIFO size, register will be set to FIFO size. Unlimited payload size is not supported in this IP.</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-only</access>
                </field>

              </fields>
           </register>

      <!-- MXDS2_W: Applicable only when Target is configured with Maximum Data Speed Limitation -->
            <register>
              <name>MXDS2_W</name>
              <description>Applicable only when Target is configured with Maximum Data Speed Limitation</description>
              <addressOffset>0x0230</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- mxds2_w_defbyte: 0 - Target does not support defining byte for GETMXDS CCC., 1 - Target supports defining byte for GETMXDS CCC.  -->
                <field>
                  <name>mxds2_w_defbyte</name>
                  <description>0 - Target does not support defining byte for GETMXDS CCC., 1 - Target supports defining byte for GETMXDS CCC. </description>
                  <bitRange>[3:3]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- mxds2_w_rate: Maximum Sustained Data Rate for non-CCC Messages sent by Controller Device to Target Device. 0 - fSCL Max (default value), 1 - 8 MHz, 2 - 6 MHz, 3 - 4 MHz, 4 - 2 MHz, Others - Reserved for future use by MIPI Alliance -->
                <field>
                  <name>mxds2_w_rate</name>
                  <description>Maximum Sustained Data Rate for non-CCC Messages sent by Controller Device to Target Device. 0 - fSCL Max (default value), 1 - 8 MHz, 2 - 6 MHz, 3 - 4 MHz, 4 - 2 MHz, Others - Reserved for future use by MIPI Alliance</description>
                  <bitRange>[2:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- MXDS2_R: Applicable only when Target is configured with Maximum Data Speed Limitation -->
            <register>
              <name>MXDS2_R</name>
              <description>Applicable only when Target is configured with Maximum Data Speed Limitation</description>
              <addressOffset>0x0234</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- mxds2_r_wr2rd_stop: If maximum read turnaround time is not 0, then this field is used to tell the Controller whether the Target permits the Write-to-Read to be split by a STOP. 0 - STOP would cancel the Read, 1 - The Target permits the Write-to-Read to be split by a STOP (not supported in this IP) -->
                <field>
                  <name>mxds2_r_wr2rd_stop</name>
                  <description>If maximum read turnaround time is not 0, then this field is used to tell the Controller whether the Target permits the Write-to-Read to be split by a STOP. 0 - STOP would cancel the Read, 1 - The Target permits the Write-to-Read to be split by a STOP (not supported in this IP)</description>
                  <bitRange>[6:6]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- mxds2_r_tsco: Clock to Data Turnaround Time (tSCO). 0 - less than or equal to 8 ns (default value), 1 - less than or equal to 9 ns, 2 - less than or equal to 10 ns, 3 - less than or equal to 11 ns, 4 - less than or equal to 12 ns, 5, 6 - Reserved for future use by MIPI Alliance, 7 - tSCO is > 12 ns, and is reported by private agreement -->
                <field>
                  <name>mxds2_r_tsco</name>
                  <description>Clock to Data Turnaround Time (tSCO). 0 - less than or equal to 8 ns (default value), 1 - less than or equal to 9 ns, 2 - less than or equal to 10 ns, 3 - less than or equal to 11 ns, 4 - less than or equal to 12 ns, 5, 6 - Reserved for future use by MIPI Alliance, 7 - tSCO is > 12 ns, and is reported by private agreement</description>
                  <bitRange>[5:3]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- mxds2_r_rate: Maximum Sustained Data Rate for non-CCC Messages sent by Target Device to Controller Device. 0 - fSCL Max (default value), 1 - 8 MHz, 2 - 6 MHz, 3 - 4 MHz, 4 - 2 MHz, Others - Reserved for future use by MIPI Alliance -->
                <field>
                  <name>mxds2_r_rate</name>
                  <description>Maximum Sustained Data Rate for non-CCC Messages sent by Target Device to Controller Device. 0 - fSCL Max (default value), 1 - 8 MHz, 2 - 6 MHz, 3 - 4 MHz, 4 - 2 MHz, Others - Reserved for future use by MIPI Alliance</description>
                  <bitRange>[2:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- MAX_RDTURN_B2: Applicable only when Target is configured with Maximum Data Speed Limitation -->
            <register>
              <name>MAX_RDTURN_B2</name>
              <description>Applicable only when Target is configured with Maximum Data Speed Limitation</description>
              <addressOffset>0x0238</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- max_rdturn_b2: Maximum Read Turnaround Time in us. Most significant byte of 24-bit field that can encode turnaround times from 0.0 seconds to 16 seconds. -->
                <field>
                  <name>max_rdturn_b2</name>
                  <description>Maximum Read Turnaround Time in us. Most significant byte of 24-bit field that can encode turnaround times from 0.0 seconds to 16 seconds.</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- MAX_RDTURN_B1: Applicable only when Target is configured with Maximum Data Speed Limitation -->
            <register>
              <name>MAX_RDTURN_B1</name>
              <description>Applicable only when Target is configured with Maximum Data Speed Limitation</description>
              <addressOffset>0x023C</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- max_rdturn_b1: Maximum Read Turnaround Time in us. Middle byte of 24-bit field that can encode turnaround times from 0.0 seconds to 16 seconds. -->
                <field>
                  <name>max_rdturn_b1</name>
                  <description>Maximum Read Turnaround Time in us. Middle byte of 24-bit field that can encode turnaround times from 0.0 seconds to 16 seconds.</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- MAX_RDTURN_B0: Applicable only when Target is configured with Maximum Data Speed Limitation -->
            <register>
              <name>MAX_RDTURN_B0</name>
              <description>Applicable only when Target is configured with Maximum Data Speed Limitation</description>
              <addressOffset>0x0240</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- max_rdturn_b0: Maximum Read Turnaround Time in us. Least significant byte of 24-bit field that can encode turnaround times from 0.0 seconds to 16 seconds. -->
                <field>
                  <name>max_rdturn_b0</name>
                  <description>Maximum Read Turnaround Time in us. Least significant byte of 24-bit field that can encode turnaround times from 0.0 seconds to 16 seconds.</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- PID_BYTE6: 6th Byte of Target Device PID. -->
            <register>
              <name>PID_BYTE6</name>
              <description>6th Byte of Target Device PID.</description>
              <addressOffset>0x0244</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- pid_manuf1: Bits 14:7 of 15-bit MIPI Manufacturer ID. Reset value may be configured by User  via Manufacturer ID attribute. -->
                <field>
                  <name>pid_manuf1</name>
                  <description>Bits 14:7 of 15-bit MIPI Manufacturer ID. Reset value may be configured by User  via Manufacturer ID attribute.</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- PID_BYTE5: 5th Byte of Target Device PID. -->
            <register>
              <name>PID_BYTE5</name>
              <description>5th Byte of Target Device PID.</description>
              <addressOffset>0x0248</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- pid_manuf0: Bits 6:0 of 15-bit MIPI Manufacturer ID. Reset value may be configured by User  via Manufacturer ID attribute. -->
                <field>
                  <name>pid_manuf0</name>
                  <description>Bits 6:0 of 15-bit MIPI Manufacturer ID. Reset value may be configured by User  via Manufacturer ID attribute.</description>
                  <bitRange>[7:1]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- pid_type_sel: Provisioned ID type selector. 0 - Vendor Fixed Value, 1 - Random value generated by device (Not supported in this IP) -->
                <field>
                  <name>pid_type_sel</name>
                  <description>Provisioned ID type selector. 0 - Vendor Fixed Value, 1 - Random value generated by device (Not supported in this IP)</description>
                  <bitRange>[0:0]</bitRange>
                  <access>read-only</access>
                </field>

              </fields>
           </register>

      <!-- PID_BYTE4: 4th Byte of Target Device PID. -->
            <register>
              <name>PID_BYTE4</name>
              <description>4th Byte of Target Device PID.</description>
              <addressOffset>0x024C</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- pid_part1: Bits 15:8 of 16-bit Part ID when pid_type_sel is 0. The meaning of this 16-bit field is left to the Device vendor to define. Reset value may be configured by User  via Part ID attribute. -->
                <field>
                  <name>pid_part1</name>
                  <description>Bits 15:8 of 16-bit Part ID when pid_type_sel is 0. The meaning of this 16-bit field is left to the Device vendor to define. Reset value may be configured by User  via Part ID attribute.</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- PID_BYTE3: 3rd Byte of Target Device PID. -->
            <register>
              <name>PID_BYTE3</name>
              <description>3rd Byte of Target Device PID.</description>
              <addressOffset>0x0250</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- pid_part0: Bits 7:0 of 16-bit Part ID when pid_type_sel is 0. The meaning of this 16-bit field is left to the Device vendor to define. Reset value may be configured by User  via Part ID attribute. -->
                <field>
                  <name>pid_part0</name>
                  <description>Bits 7:0 of 16-bit Part ID when pid_type_sel is 0. The meaning of this 16-bit field is left to the Device vendor to define. Reset value may be configured by User  via Part ID attribute.</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- PID_BYTE2: 2nd Byte of Target Device PID. -->
            <register>
              <name>PID_BYTE2</name>
              <description>2nd Byte of Target Device PID.</description>
              <addressOffset>0x0254</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- pid_inst: Instance ID field that should identify the individual Device, using a method selected by the system designer (e.g., straps, fuses, non-volatile memory, or another appropriate method). Reset value may be configured by User  via Instance ID attribute. -->
                <field>
                  <name>pid_inst</name>
                  <description>Instance ID field that should identify the individual Device, using a method selected by the system designer (e.g., straps, fuses, non-volatile memory, or another appropriate method). Reset value may be configured by User  via Instance ID attribute.</description>
                  <bitRange>[7:4]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- pid_add1: Bits 11:8 of 12-bit Additional ID for definitions with additional meaning (e.g., Deeper device characteristics that may optionally include Device Characteristics Register values). Reset value may be configured by User  via Additional ID attribute. -->
                <field>
                  <name>pid_add1</name>
                  <description>Bits 11:8 of 12-bit Additional ID for definitions with additional meaning (e.g., Deeper device characteristics that may optionally include Device Characteristics Register values). Reset value may be configured by User  via Additional ID attribute.</description>
                  <bitRange>[3:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- PID_BYTE1: 1st Byte of Target Device PID. -->
            <register>
              <name>PID_BYTE1</name>
              <description>1st Byte of Target Device PID.</description>
              <addressOffset>0x0258</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- pid_add0: Bits 7:0 of 12-bit Additional ID for definitions with additional meaning (e.g., Deeper device characteristics that may optionally include Device Characteristics Register values). Reset value may be configured by User  via Additional ID attribute. -->
                <field>
                  <name>pid_add0</name>
                  <description>Bits 7:0 of 12-bit Additional ID for definitions with additional meaning (e.g., Deeper device characteristics that may optionally include Device Characteristics Register values). Reset value may be configured by User  via Additional ID attribute.</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- STAT_ADDR: 1st Byte of Target Device PID. -->
            <register>
              <name>STAT_ADDR</name>
              <description>1st Byte of Target Device PID.</description>
              <addressOffset>0x025C</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- stat_addr: Target Static Address assigned by User. Reset value may be configured by User via Static Address attribute. If static address is disabled, reset value is 0. -->
                <field>
                  <name>stat_addr</name>
                  <description>Target Static Address assigned by User. Reset value may be configured by User via Static Address attribute. If static address is disabled, reset value is 0.</description>
                  <bitRange>[6:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- GETCAPS_B1: Device capabilities that Target returns when Controller sends GETCAPS CCC. -->
            <register>
              <name>GETCAPS_B1</name>
              <description>Device capabilities that Target returns when Controller sends GETCAPS CCC.</description>
              <addressOffset>0x0260</addressOffset>
              <size>32</size>
              <access>read-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- hdr_bt_mode: Fixed to 0. HDR-BT mode is not supported. -->
                <field>
                  <name>hdr_bt_mode</name>
                  <description>Fixed to 0. HDR-BT mode is not supported.</description>
                  <bitRange>[3:3]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- hdr_tsl_mode: Fixed to 0. HDR-BT mode is not supported. -->
                <field>
                  <name>hdr_tsl_mode</name>
                  <description>Fixed to 0. HDR-BT mode is not supported.</description>
                  <bitRange>[2:2]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- hdr_tsp_mode: Fixed to 0. HDR-BT mode is not supported. -->
                <field>
                  <name>hdr_tsp_mode</name>
                  <description>Fixed to 0. HDR-BT mode is not supported.</description>
                  <bitRange>[1:1]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- hdr_ddr_mode: Set to 1 when device is configured with HDR capability. Only HDR-DDR mode is supported. -->
                <field>
                  <name>hdr_ddr_mode</name>
                  <description>Set to 1 when device is configured with HDR capability. Only HDR-DDR mode is supported.</description>
                  <bitRange>[0:0]</bitRange>
                  <access>read-only</access>
                </field>

              </fields>
           </register>

      <!-- GETCAPS_B2: Device capabilities that Target returns when Controller sends GETCAPS CCC. -->
            <register>
              <name>GETCAPS_B2</name>
              <description>Device capabilities that Target returns when Controller sends GETCAPS CCC.</description>
              <addressOffset>0x0264</addressOffset>
              <size>32</size>
              <access>read-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- hdr_ddr_abort_crc: I3C Target capability of emitting the CRC Word when a transaction in HDR-DDR Mode is aborted. Set to 1 when device is configured with HDR capability. 0 - No, 1 - Yes -->
                <field>
                  <name>hdr_ddr_abort_crc</name>
                  <description>I3C Target capability of emitting the CRC Word when a transaction in HDR-DDR Mode is aborted. Set to 1 when device is configured with HDR capability. 0 - No, 1 - Yes</description>
                  <bitRange>[7:7]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- hdr_ddr_wr_abort: I3C Target capability of issuing the Write Abort in HDR-DDR Mode. Set to 1 when device is configured with HDR capability. 0 - No, 1 - Yes -->
                <field>
                  <name>hdr_ddr_wr_abort</name>
                  <description>I3C Target capability of issuing the Write Abort in HDR-DDR Mode. Set to 1 when device is configured with HDR capability. 0 - No, 1 - Yes</description>
                  <bitRange>[6:6]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- grp_adr_caps: Indicates the Group Address function capabilities of this I3C Device. Fixed to 0. IP does not support Group Address function. -->
                <field>
                  <name>grp_adr_caps</name>
                  <description>Indicates the Group Address function capabilities of this I3C Device. Fixed to 0. IP does not support Group Address function.</description>
                  <bitRange>[5:4]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- i3c_spec_ver: Indicates the minor version number of the MIPI I3C Specification with which this I3C v1.x Device complies (i.e., the 'x' in I3C v1.x). Setting to 0x is illegal. -->
                <field>
                  <name>i3c_spec_ver</name>
                  <description>Indicates the minor version number of the MIPI I3C Specification with which this I3C v1.x Device complies (i.e., the 'x' in I3C v1.x). Setting to 0x is illegal.</description>
                  <bitRange>[3:0]</bitRange>
                  <access>read-only</access>
                </field>

              </fields>
           </register>

      <!-- GETCAPS_B3: Device capabilities that Target returns when Controller sends GETCAPS CCC. -->
            <register>
              <name>GETCAPS_B3</name>
              <description>Device capabilities that Target returns when Controller sends GETCAPS CCC.</description>
              <addressOffset>0x0268</addressOffset>
              <size>32</size>
              <access>read-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- pend_rd_mdb: I3C Target support for IBI with Pending Read Notification MDB, which the Controller shall then follow with a Private Read request to fetch the data. Set to 1 when device is configured with IBI with MDB capability. 0 - No, 1 - Yes -->
                <field>
                  <name>pend_rd_mdb</name>
                  <description>I3C Target support for IBI with Pending Read Notification MDB, which the Controller shall then follow with a Private Read request to fetch the data. Set to 1 when device is configured with IBI with MDB capability. 0 - No, 1 - Yes</description>
                  <bitRange>[6:6]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- hdr_bt_crc32: I3C Target support CRC-32 data integrity verification in HDR Bulk Transport Mode. 0 - No, 1 - Yes (Not supported in this IP) -->
                <field>
                  <name>hdr_bt_crc32</name>
                  <description>I3C Target support CRC-32 data integrity verification in HDR Bulk Transport Mode. 0 - No, 1 - Yes (Not supported in this IP)</description>
                  <bitRange>[6:5]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- getstatus_defbyte: I3C Target support for defining byte in GETSTATUS CCC. 0 - No, 1 - Yes (Not supported in this IP) -->
                <field>
                  <name>getstatus_defbyte</name>
                  <description>I3C Target support for defining byte in GETSTATUS CCC. 0 - No, 1 - Yes (Not supported in this IP)</description>
                  <bitRange>[6:4]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- getcaps_defbyte: I3C Target support for defining byte in GETCAPS CCC. 0 - No, 1 - Yes (Not supported in this IP) -->
                <field>
                  <name>getcaps_defbyte</name>
                  <description>I3C Target support for defining byte in GETCAPS CCC. 0 - No, 1 - Yes (Not supported in this IP)</description>
                  <bitRange>[6:3]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- d2dxfer_ibi: I3C Target capability to initiate Device to Device (D2D) Transfer using IBI with MDB 0x37. 0 - No, 1 - Yes (Not supported in this IP) -->
                <field>
                  <name>d2dxfer_ibi</name>
                  <description>I3C Target capability to initiate Device to Device (D2D) Transfer using IBI with MDB 0x37. 0 - No, 1 - Yes (Not supported in this IP)</description>
                  <bitRange>[6:2]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- d2dxfer: I3C Target support for D2D transfers either as a Source or a Subscriber/Receiver. 0 - No, 1 - Yes (Not supported in this IP) -->
                <field>
                  <name>d2dxfer</name>
                  <description>I3C Target support for D2D transfers either as a Source or a Subscriber/Receiver. 0 - No, 1 - Yes (Not supported in this IP)</description>
                  <bitRange>[6:1]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- ml_data_xfer: I3C Target support for Multi-Lane data transfer. 0 - No, 1 - Yes (Not supported in this IP) -->
                <field>
                  <name>ml_data_xfer</name>
                  <description>I3C Target support for Multi-Lane data transfer. 0 - No, 1 - Yes (Not supported in this IP)</description>
                  <bitRange>[6:0]</bitRange>
                  <access>read-only</access>
                </field>

              </fields>
           </register>

      <!-- OSC_INACCURACY: Inaccuracy of Target's internal oscillator. -->
            <register>
              <name>OSC_INACCURACY</name>
              <description>Inaccuracy of Target's internal oscillator.</description>
              <addressOffset>0x0270</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- osc_inaccuracy: Describes the maximum variation of the Target's internal oscillator in 1/10th percent (0.1%) increments, up to 25.5%. -->
                <field>
                  <name>osc_inaccuracy</name>
                  <description>Describes the maximum variation of the Target's internal oscillator in 1/10th percent (0.1%) increments, up to 25.5%.</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- RX_FIFO: Receive FIFO -->
            <register>
              <name>RX_FIFO</name>
              <description>Receive FIFO</description>
              <addressOffset>0x0280</addressOffset>
              <size>32</size>
              <access>read-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- rx_fifo: Data bytes received from I3C bus are stored in this FIFO. User can get the received data by reading from this address multiple times depending on the number of data bytes to be read. User may read rxfifo_not_empty interrupt status register (Interrupt Status 2 Bit 6) first to determine if there is data to be read from rx_fifo. -->
                <field>
                  <name>rx_fifo</name>
                  <description>Data bytes received from I3C bus are stored in this FIFO. User can get the received data by reading from this address multiple times depending on the number of data bytes to be read. User may read rxfifo_not_empty interrupt status register (Interrupt Status 2 Bit 6) first to determine if there is data to be read from rx_fifo.</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-only</access>
                </field>

              </fields>
           </register>

      <!-- TX_FIFO: Transmit FIFO -->
            <register>
              <name>TX_FIFO</name>
              <description>Transmit FIFO</description>
              <addressOffset>0x0288</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- tx_fifo: Data to be sent to I3C bus are stored in this FIFO. User can do multiple writes to this address depending on the number of data bytes to be written. Reading from this address will indicate txfifo_empty status (0x1 - Empty, 0x - Not Empty). -->
                <field>
                  <name>tx_fifo</name>
                  <description>Data to be sent to I3C bus are stored in this FIFO. User can do multiple writes to this address depending on the number of data bytes to be written. Reading from this address will indicate txfifo_empty status (0x1 - Empty, 0x - Not Empty).</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- SOFT_RESET: Soft Reset -->
            <register>
              <name>SOFT_RESET</name>
              <description>Soft Reset</description>
              <addressOffset>0x02A0</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- ip_csr_rst: When set to high, resets the IP read-write and write-only registers only. Auto-clear. -->
                <field>
                  <name>ip_csr_rst</name>
                  <description>When set to high, resets the IP read-write and write-only registers only. Auto-clear.</description>
                  <bitRange>[4:4]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- ip_core_rst: When set to high, resets the internal state of I3C Target Core only (including Tx and Rx FIFO). Dynamic address and configurations via CCCs are not reset. -->
                <field>
                  <name>ip_core_rst</name>
                  <description>When set to high, resets the internal state of I3C Target Core only (including Tx and Rx FIFO). Dynamic address and configurations via CCCs are not reset.</description>
                  <bitRange>[3:3]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- tx_fifo_rst: When set to high, resets the Tx FIFO only. Auto-clear. -->
                <field>
                  <name>tx_fifo_rst</name>
                  <description>When set to high, resets the Tx FIFO only. Auto-clear.</description>
                  <bitRange>[2:2]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- rx_fifo_rst: When set to high, resets the Rx FIFO only. Auto-clear. -->
                <field>
                  <name>rx_fifo_rst</name>
                  <description>When set to high, resets the Rx FIFO only. Auto-clear.</description>
                  <bitRange>[1:1]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- ip_main_rst: When set to high, resets the whole IP including registers, FIFO, dynamic address, and CCC configurations. Auto-clear. -->
                <field>
                  <name>ip_main_rst</name>
                  <description>When set to high, resets the whole IP including registers, FIFO, dynamic address, and CCC configurations. Auto-clear.</description>
                  <bitRange>[0:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- TGT_ACKNAK: Target Response -->
            <register>
              <name>TGT_ACKNAK</name>
              <description>Target Response</description>
              <addressOffset>0x02A4</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- fifo_loopback_en: 0 - Data written through Private Write will be read from Rx FIFO. Data written to Tx FIFO will be read through Private Read. 1 - Data written through Private Write will be stored in Rx FIFO and transferred to Tx FIFO to be read through Private Read. Data written to the Tx FIFO by the User can still be read through Private Read. -->
                <field>
                  <name>fifo_loopback_en</name>
                  <description>0 - Data written through Private Write will be read from Rx FIFO. Data written to Tx FIFO will be read through Private Read. 1 - Data written through Private Write will be stored in Rx FIFO and transferred to Tx FIFO to be read through Private Read. Data written to the Tx FIFO by the User can still be read through Private Read.</description>
                  <bitRange>[4:4]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- txfifo_empty_rd_nak: Target response when Controller reads but Tx FIFO is empty
0 - In SDR mode, Target will ACK its Address and return 0xFF read data then End-of-Message by pulling SDA Low at T-bit. If I3C bus is in HDR mode and Target is configured with HDR capability, Target will ACK its address and return 0x data then end Read. 1 - Target will NACK its Address -->
                <field>
                  <name>txfifo_empty_rd_nak</name>
                  <description>Target response when Controller reads but Tx FIFO is empty
0 - In SDR mode, Target will ACK its Address and return 0xFF read data then End-of-Message by pulling SDA Low at T-bit. If I3C bus is in HDR mode and Target is configured with HDR capability, Target will ACK its address and return 0x data then end Read. 1 - Target will NACK its Address</description>
                  <bitRange>[0:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- GET_STATUS_MSB: Most significant byte that the Target returns when Controller sends GETSTATUS CCC -->
            <register>
              <name>GET_STATUS_MSB</name>
              <description>Most significant byte that the Target returns when Controller sends GETSTATUS CCC</description>
              <addressOffset>0x02A8</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- get_status_msb: Reserved for vendor-specific meaning. -->
                <field>
                  <name>get_status_msb</name>
                  <description>Reserved for vendor-specific meaning.</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- GET_STATUS_LSB: Least significant byte that the Target returns when Controller sends GETSTATUS CCC -->
            <register>
              <name>GET_STATUS_LSB</name>
              <description>Least significant byte that the Target returns when Controller sends GETSTATUS CCC</description>
              <addressOffset>0x02AC</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- activity_mode: Contains the 2-bit ID of the Target Device's current activity mode. For Target devices without secondary controller capability, the meanings of this value will depend upon a private contract between the Target and the Controller. -->
                <field>
                  <name>activity_mode</name>
                  <description>Contains the 2-bit ID of the Target Device's current activity mode. For Target devices without secondary controller capability, the meanings of this value will depend upon a private contract between the Target and the Controller.</description>
                  <bitRange>[7:6]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- pending_interrupt: Contains the interrupt number of any pending interrupt, or 0 if no interrupts are pending. -->
                <field>
                  <name>pending_interrupt</name>
                  <description>Contains the interrupt number of any pending interrupt, or 0 if no interrupts are pending.</description>
                  <bitRange>[3:0]</bitRange>
                  <access>read-write</access>
                </field>

              </fields>
           </register>

      <!-- BUS_ACT_STATE: Least significant byte that the Target returns when Controller sends GETSTATUS CCC -->
            <register>
              <name>BUS_ACT_STATE</name>
              <description>Least significant byte that the Target returns when Controller sends GETSTATUS CCC</description>
              <addressOffset>0x02B0</addressOffset>
              <size>32</size>
              <access>read-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- bus_act: When bus_act_rcvd is set to 1, this register indicates the activity state received. Write 1 to clear. 0 - 1 us (Latency-free,operation), 1 - 100 us, 2 - 2ms, 3 - 50ms (Lowest-activity operation) -->
                <field>
                  <name>bus_act</name>
                  <description>When bus_act_rcvd is set to 1, this register indicates the activity state received. Write 1 to clear. 0 - 1 us (Latency-free,operation), 1 - 100 us, 2 - 2ms, 3 - 50ms (Lowest-activity operation)</description>
                  <bitRange>[1:0]</bitRange>
                  <access>read-only</access>
                </field>

              </fields>
           </register>

      <!-- TGT_RST_ACT0: Target Reset Action Information 1 -->
            <register>
              <name>TGT_RST_ACT0</name>
              <description>Target Reset Action Information 1</description>
              <addressOffset>0x02B4</addressOffset>
              <size>32</size>
              <access>read-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- rst_act: Target Reset Action configured by the Controller via Defining Byte of RSTACT CCC. When Target Reset Pattern is received after RSTACT CCC, User shall perform the configured reset action. -->
                <field>
                  <name>rst_act</name>
                  <description>Target Reset Action configured by the Controller via Defining Byte of RSTACT CCC. When Target Reset Pattern is received after RSTACT CCC, User shall perform the configured reset action.</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-only</access>
                </field>

              </fields>
           </register>

      <!-- TGT_RST_ACT1: Target Reset Action Information 2 -->
            <register>
              <name>TGT_RST_ACT1</name>
              <description>Target Reset Action Information 2</description>
              <addressOffset>0x02B8</addressOffset>
              <size>32</size>
              <access>read-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- rst_act_set0_get1: 0 - Controller configured Target Reset Action by Direct SET RSTACT CCC, 1 - Controller configured Target Reset Action by Direct GET RSTACT CCC -->
                <field>
                  <name>rst_act_set0_get1</name>
                  <description>0 - Controller configured Target Reset Action by Direct SET RSTACT CCC, 1 - Controller configured Target Reset Action by Direct GET RSTACT CCC</description>
                  <bitRange>[1:1]</bitRange>
                  <access>read-only</access>
                </field>
            <!-- rst_act_broad0_dir1: 0 - Controller configured Target Reset Action by Broadcast RSTACT CCC, 1 - Controller configured Target Reset Action by Direct Set/Get RSTACT CCC -->
                <field>
                  <name>rst_act_broad0_dir1</name>
                  <description>0 - Controller configured Target Reset Action by Broadcast RSTACT CCC, 1 - Controller configured Target Reset Action by Direct Set/Get RSTACT CCC</description>
                  <bitRange>[0:0]</bitRange>
                  <access>read-only</access>
                </field>

              </fields>
           </register>

      <!-- TGT_RST_ACT2: Target Reset Action Information 3 -->
            <register>
              <name>TGT_RST_ACT2</name>
              <description>Target Reset Action Information 3</description>
              <addressOffset>0x02BC</addressOffset>
              <size>32</size>
              <access>read-only</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- rst_act_set: Target Reset Action configured by the Controller via Defining Byte of Direct SET RSTACT CCC. This is the value returned by Target when Controller sends Direct GET CCC. -->
                <field>
                  <name>rst_act_set</name>
                  <description>Target Reset Action configured by the Controller via Defining Byte of Direct SET RSTACT CCC. This is the value returned by Target when Controller sends Direct GET CCC.</description>
                  <bitRange>[7:0]</bitRange>
                  <access>read-only</access>
                </field>

              </fields>
           </register>

      <!-- STAT1_INT: Interrupt Status 1 -->
            <register>
              <name>STAT1_INT</name>
              <description>Interrupt Status 1</description>
              <addressOffset>0x02C0</addressOffset>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <resetMask>0xFFFFFFFF</resetMask>

              <fields>
                          <!-- hj_req_gen: When set to 1, Hot-Join request is generated by Target. Write 1 to clear. -->
                <field>
                  <name>hj_req_gen</name>
                  <description>When set to 1, Hot-Join request is generated by Target. Write 1 to clear.</description>
                  <bitRange>[7:7]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- hj_done: When set to 1, Hot-Join address with Write bit is transmitted by Target and Controller has either ACKed or NACKed for HJ_IBI_RETRY times. Write 1 to clear. -->
                <field>
                  <name>hj_done</name>
                  <description>When set to 1, Hot-Join address with Write bit is transmitted by Target and Controller has either ACKed or NACKed for HJ_IBI_RETRY times. Write 1 to clear.</description>
                  <bitRange>[6:6]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- hj_acknack: When set to 1, Hot-Join is NACKed by Controller after HJ_IBI_RETRY times. Write 1 to clear. -->
                <field>
                  <name>hj_acknack</name>
                  <description>When set to 1, Hot-Join is NACKed by Controller after HJ_IBI_RETRY times. Write 1 to clear.</description>
                  <bitRange>[5:5]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- ibi_req_gen: When set to 1, IBI request is generated by Target. Write 1 to clear. -->
                <field>
                  <name>ibi_req_gen</name>
                  <description>When set to 1, IBI request is generated by Target. Write 1 to clear.</description>
                  <bitRange>[3:3]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- ibi_done: When set to 1, Target Address with Read bit has been transmitted by Target and Controller has either ACKED or NACKed the request for HJ_IBI_RETRY times. If with payload, IBI payload has been transmitted and finished either by End-of-Data (from Target) or STOP (from Controller). Write 1 to clear. -->
                <field>
                  <name>ibi_done</name>
                  <description>When set to 1, Target Address with Read bit has been transmitted by Target and Controller has either ACKED or NACKed the request for HJ_IBI_RETRY times. If with payload, IBI payload has been transmitted and finished either by End-of-Data (from Target) or STOP (from Controller). Write 1 to clear.</description>
                  <bitRange>[2:2]</bitRange>
                  <access>read-write</access>
                </field>
            <!-- ibi_acknack: When set to 1, IBI is NACKed by Controller after HJ_IBI_RETRY times. Write 1 to clear. -->
                <field>
                  <name>ibi_acknack</name>
